 lib/list_sort.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/lib/list_sort.c b/lib/list_sort.c
index e8ff17c9b2d08..ff99203f208f8 100644
--- a/lib/list_sort.c
+++ b/lib/list_sort.c
@@ -50,7 +50,6 @@ static void merge_final(void *priv, list_cmp_func_t cmp, struct list_head *head,
