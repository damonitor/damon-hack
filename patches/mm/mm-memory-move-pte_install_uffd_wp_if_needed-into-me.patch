index 41561fdeb56d0..36427f566da93 100644
--- a/mm/internal.h
+++ b/mm/internal.h
@@ -280,6 +280,9 @@ void unmap_vmas(struct mmu_gather *tlb, struct unmap_desc *unmap);
 
 #ifdef CONFIG_MMU
 
