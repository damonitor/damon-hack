 1 file changed, 4 insertions(+)

diff --git a/mm/nommu.c b/mm/nommu.c
index 11fd558be5ede..815ebefddfaef 100644
--- a/mm/nommu.c
+++ b/mm/nommu.c
@@ -1370,6 +1370,10 @@ static int split_vma(struct vma_iterator *vmi, struct vm_area_struct *vma,
 	setup_vma_to_mm(vma, mm);
 	setup_vma_to_mm(new, mm);
 	vma_iter_store_new(vmi, new);
+
+	/* vmi should point lower address */
+	if (new_below)
+		vma_next(vmi);
 	mm->map_count++;
 	return 0;
 
