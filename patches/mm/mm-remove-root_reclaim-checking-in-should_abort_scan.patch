diff --git a/mm/vmscan.c b/mm/vmscan.c
index e30a11d22086c..05a6800f1fa68 100644
--- a/mm/vmscan.c
+++ b/mm/vmscan.c
@@ -4969,10 +4969,6 @@ static bool should_abort_scan(struct lruvec *lruvec, struct scan_control *sc)
 	int i;
 	enum zone_watermarks mark;
 
-	/* don't abort memcg reclaim to ensure fairness */
-	if (!root_reclaim(sc))
-		return false;
-
 	if (sc->nr_reclaimed >= max(sc->nr_to_reclaim, compact_gap(sc->order)))
 		return true;
 
