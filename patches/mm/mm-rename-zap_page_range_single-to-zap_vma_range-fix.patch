From: Andrew Morton <akpm@linux-foundation.org>
Date: Wed, 18 Mar 2026 11:18:24 -0700
Subject: [PATCH] mm-rename-zap_page_range_single-to-zap_vma_range-fix

fix rustfmtcheck

Reported-by: Mark Brown <broonie@kernel.org>
Cc: David Hildenbrand <david@kernel.org>
Cc: Lorenzo Stoakes (Oracle) <ljs@kernel.org>
Cc: Puranjay Mohan <puranjay@kernel.org>
Signed-off-by: Andrew Morton <akpm@linux-foundation.org>
---
 drivers/android/binder/page_range.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/android/binder/page_range.rs b/drivers/android/binder/page_range.rs
index ffd2ff38835d0..8882fd18d9f3f 100644
--- a/drivers/android/binder/page_range.rs
+++ b/drivers/android/binder/page_range.rs
@@ -762,7 +762,7 @@ fn drop(self: Pin<&mut Self>) {
     if let Some(unchecked_vma) = mmap_read.vma_lookup(vma_addr) {
         if let Some(vma) = check_vma(unchecked_vma, range_ptr) {
             let user_page_addr = vma_addr + (page_index << PAGE_SHIFT);
-        vma.zap_vma_range(user_page_addr, PAGE_SIZE);
+            vma.zap_vma_range(user_page_addr, PAGE_SIZE);
         }
     }
 
-- 
2.47.3

