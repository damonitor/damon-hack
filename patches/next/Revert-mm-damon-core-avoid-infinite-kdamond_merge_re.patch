From: SJ Park <sj@kernel.org>
Date: Fri, 10 Jul 2026 18:38:16 -0700
Subject: [PATCH] Revert "mm/damon/core: avoid infinite kdamond_merge_regions()
 internal loop"

This reverts commit 1d9bec96fae6df09d4b0dd1774dc8093e5a9d7b5.

This makes damon_nr_regions.py selftest fails.

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 93696234800a7..3e4a616d9765f 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -3729,7 +3729,7 @@ static void kdamond_merge_regions(struct damon_ctx *c, unsigned int threshold,
 		count_age = false;
 		threshold = max(1, threshold * 2);
 	} while (nr_regions > c->attrs.max_nr_regions &&
-			threshold <= max_thres / 2);
+			threshold / 2 < max_thres);
 }
 
 #ifdef CONFIG_DAMON_DEBUG_SANITY
-- 
2.47.3

