From: SeongJae Park <sj@kernel.org>
Date: Mon, 11 May 2026 20:46:52 -0700
Subject: [PATCH] Revert "mm/damon: s/DAMON_TEST_TYPE/DAMON_FILTER_TYPE/"

This reverts commit 8f9ca364ad7cd96d26d0fe228dc41bc91970edbf.

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h | 4 ++--
 mm/damon/paddr.c      | 2 +-
 mm/damon/sysfs.c      | 2 +-
 3 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index a3aa61cff0cd8..d4fe42a641146 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -739,10 +739,10 @@ struct damon_intervals_goal {
 /**
  * enum damon_filter_type - Type of &struct damon_filter
  *
- * @DAMON_FILTER_TYPE_ANON:	Anonymous pages.
+ * @DAMON_TEST_TYPE_ANON:	Anonymous pages.
  */
 enum damon_filter_type {
-	DAMON_FILTER_TYPE_ANON,
+	DAMON_TEST_TYPE_ANON,
 };
 
 /**
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index c3fd939f7d8e1..5d9636f23a66f 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -128,7 +128,7 @@ static bool damon_pa_filter_pass(phys_addr_t pa, struct damon_probe *p)
 	damon_for_each_filter(f, p) {
 		bool matched = false;
 
-		if (f->type == DAMON_FILTER_TYPE_ANON) {
+		if (f->type == DAMON_TEST_TYPE_ANON) {
 			struct folio *folio = damon_get_folio(PHYS_PFN(pa));
 
 			if (folio)
diff --git a/mm/damon/sysfs.c b/mm/damon/sysfs.c
index e49ffaa3be5fb..8007961295d3d 100644
--- a/mm/damon/sysfs.c
+++ b/mm/damon/sysfs.c
@@ -771,7 +771,7 @@ struct damon_sysfs_filter_type_name {
 static const struct damon_sysfs_filter_type_name
 damon_sysfs_filter_type_names[] = {
 	{
-		.type = DAMON_FILTER_TYPE_ANON,
+		.type = DAMON_TEST_TYPE_ANON,
 		.name = "anon",
 	},
 };
-- 
