Subject: [PATCH] add -damon suffix to the version name

Append -damon suffix to the kernel version name.

Signed-off-by: SJ Park <sj@kernel.org>
---
 Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Makefile b/Makefile
index 11539c3fd405c..7ace235b6ca4d 100644
--- a/Makefile
+++ b/Makefile
@@ -2,7 +2,7 @@
 VERSION = 7
 PATCHLEVEL = 2
 SUBLEVEL = 0
-EXTRAVERSION = -rc4
+EXTRAVERSION = -rc4-mm-new-damon
 NAME = Baby Opossum Posse
 
 # *DOCUMENTATION*
