From: SJ Park <sj@kernel.org>
Date: Tue, 9 Jun 2026 22:28:26 -0700
Subject: [PATCH] mm/damon/acma: assume damon_stop() to always succeed

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/acma.c | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/mm/damon/acma.c b/mm/damon/acma.c
index 2082853ce9149..67d592386670b 100644
--- a/mm/damon/acma.c
+++ b/mm/damon/acma.c
@@ -435,10 +435,9 @@ static int damon_acma_turn(bool on)
 	int err;
 
 	if (!on) {
-		err = damon_stop(&ctx, 1);
-		if (!err)
-			kdamond_pid = -1;
-		return err;
+		damon_stop(&ctx, 1);
+		kdamond_pid = -1;
+		return 0;
 	}
 
 	err = damon_acma_apply_parameters();
-- 
2.47.3

