From: SeongJae Park <sj@kernel.org>
Date: Sun, 7 Jun 2026 14:31:52 -0700
Subject: [PATCH] mm/damon: add damon_region->last_probe_hits

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h |  1 +
 mm/damon/core.c       | 10 ++++++++--
 2 files changed, 9 insertions(+), 2 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index d2c2e65693b96..d66800bb9ea56 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -71,6 +71,7 @@ struct damon_region {
 /* private: */
 	/* List head for siblings. */
 	struct list_head list;
+	unsigned char last_probe_hits[DAMON_MAX_PROBES];
 /* public: */
 
 	unsigned int age;
diff --git a/mm/damon/core.c b/mm/damon/core.c
index fefc5076d6b0c..6c9655053d7ec 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -266,8 +266,10 @@ struct damon_region *damon_new_region(unsigned long start, unsigned long end)
 	region->ar.start = start;
 	region->ar.end = end;
 	region->nr_accesses = 0;
-	for (i = 0; i < DAMON_MAX_PROBES; i++)
+	for (i = 0; i < DAMON_MAX_PROBES; i++) {
 		region->probe_hits[i] = 0;
+		region->last_probe_hits[i] = 0;
+	}
 	INIT_LIST_HEAD(&region->list);
 
 	region->age = 0;
@@ -2252,8 +2254,10 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 					damon_nr_regions(t), nr_probes);
 			r->last_nr_accesses = r->nr_accesses;
 			r->nr_accesses = 0;
-			for (i = 0; i < DAMON_MAX_PROBES; i++)
+			for (i = 0; i < DAMON_MAX_PROBES; i++) {
+				r->last_probe_hits[i] = r->probe_hits[i];
 				r->probe_hits[i] = 0;
+			}
 		}
 		ti++;
 	}
@@ -3461,6 +3465,8 @@ static void damon_split_region_at(struct damon_target *t,
 	new->nr_accesses = r->nr_accesses;
 	/* todo: do this for only installed probes */
 	memcpy(new->probe_hits, r->probe_hits, sizeof(r->probe_hits));
+	memcpy(new->last_probe_hits, r->last_probe_hits,
+			sizeof(r->last_probe_hits));
 
 	damon_insert_region(new, r, damon_next_region(r), t);
 }
-- 
2.47.3

