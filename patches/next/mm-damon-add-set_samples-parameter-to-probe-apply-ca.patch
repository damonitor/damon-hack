From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 13:26:48 -0700
Subject: [PATCH] mm/damon: add set_samples parameter to probe apply callback

Signed-off-by: SJ Park <sj@kernel.org>
---
 include/linux/damon.h | 2 +-
 mm/damon/paddr.c      | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index 842464c34fd99..eff27e93ba208 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -733,7 +733,7 @@ struct damon_operations {
 	void (*prepare_access_checks)(struct damon_ctx *context);
 	unsigned int (*check_accesses)(struct damon_ctx *context);
 	void (*prep_probes)(struct damon_ctx *context);
-	void (*apply_probes)(struct damon_ctx *context);
+	void (*apply_probes)(struct damon_ctx *context, bool set_samples);
 	int (*get_scheme_score)(struct damon_ctx *context,
 			struct damon_region *r, struct damos *scheme);
 	unsigned long (*apply_scheme)(struct damon_ctx *context,
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index 8167ceadbac42..c9d87aa86dfc6 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -256,7 +256,7 @@ static bool damon_pa_filter_pass(phys_addr_t pa, struct folio *folio,
 	return pass;
 }
 
-static void damon_pa_apply_probes(struct damon_ctx *ctx)
+static void damon_pa_apply_probes(struct damon_ctx *ctx, bool set_samples)
 {
 	struct damon_target *t;
 	struct damon_region *r;
@@ -268,7 +268,7 @@ static void damon_pa_apply_probes(struct damon_ctx *ctx)
 			phys_addr_t pa;
 			struct folio *folio;
 
-			if (ctx->has_probe_weights)
+			if (set_samples)
 				r->sampling_addr = damon_rand(ctx, r->ar.start,
 						r->ar.end);
 			pa = damon_pa_phys_addr(r->sampling_addr,
-- 
2.47.3

