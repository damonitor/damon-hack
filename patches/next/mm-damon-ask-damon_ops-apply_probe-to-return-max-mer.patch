From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 14:23:31 -0700
Subject: [PATCH] mm/damon: ask damon_ops->apply_probe to return max merge
 score

Signed-off-by: SJ Park <sj@kernel.org>
---
 include/linux/damon.h | 3 ++-
 mm/damon/paddr.c      | 4 +++-
 2 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index 3009b92dec875..c7cd32f74e3be 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -733,7 +733,8 @@ struct damon_operations {
 	void (*prepare_access_checks)(struct damon_ctx *context);
 	unsigned int (*check_accesses)(struct damon_ctx *context);
 	void (*prep_probes)(struct damon_ctx *context, bool set_samples);
-	void (*apply_probes)(struct damon_ctx *context, bool set_samples);
+	unsigned int (*apply_probes)(struct damon_ctx *context,
+			bool set_samples);
 	int (*get_scheme_score)(struct damon_ctx *context,
 			struct damon_region *r, struct damos *scheme);
 	unsigned long (*apply_scheme)(struct damon_ctx *context,
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index 37da7a979d926..422f493c72c1c 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -259,7 +259,8 @@ static bool damon_pa_filter_pass(phys_addr_t pa, struct folio *folio,
 	return pass;
 }
 
-static void damon_pa_apply_probes(struct damon_ctx *ctx, bool set_samples)
+static unsigned int damon_pa_apply_probes(struct damon_ctx *ctx,
+		bool set_samples)
 {
 	struct damon_target *t;
 	struct damon_region *r;
@@ -287,6 +288,7 @@ static void damon_pa_apply_probes(struct damon_ctx *ctx, bool set_samples)
 
 		}
 	}
+	return 0;
 }
 
 /*
