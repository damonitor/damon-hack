From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 14:54:53 -0700
Subject: [PATCH] mm/damon/core: fix wrong access_check_disabled use in
 kdamond_fn

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 14c2d5597270d..71975ba39f5e2 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -3717,13 +3717,13 @@ static int kdamond_fn(void *data)
 		if (kdamond_wait_activation(ctx))
 			break;
 
-		if (access_check_disabled && ctx->ops.prepare_access_checks)
+		if (!access_check_disabled && ctx->ops.prepare_access_checks)
 			ctx->ops.prepare_access_checks(ctx);
 
 		kdamond_usleep(sample_interval);
 		ctx->passed_sample_intervals++;
 
-		if (access_check_disabled)
+		if (!access_check_disabled)
 			max_nr_accesses = ctx->ops.check_accesses(ctx);
 
 		if (ctx->ops.apply_probes)
-- 
2.47.3

