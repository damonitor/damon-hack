From: SeongJae Park <sj@kernel.org>
Date: Fri, 15 May 2026 18:45:10 -0700
Subject: [PATCH] mm/damon/core: (fixup 22) commit new filter's memcgid

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index d18a0d9b24f57..4fc90b0bdac88 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -1464,6 +1464,13 @@ static int damon_commit_filters(struct damon_probe *dst,
 				src_filter->matching, src_filter->allow);
 		if (!new_filter)
 			return -ENOMEM;
+		switch (src_filter->type) {
+		case DAMON_FILTER_TYPE_MEMCG:
+			new_filter->memcg_id = src_filter->memcg_id;
+			break;
+		default:
+			break;
+		}
 		damon_add_filter(dst, new_filter);
 	}
 	return 0;
-- 
2.47.3

