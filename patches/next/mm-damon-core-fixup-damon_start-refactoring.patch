From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 11:40:33 -0700
Subject: [PATCH] mm/damon/core: fixup damon_start() refactoring

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 94ad3d35fb608..e10a5f59c47ed 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -2182,16 +2182,17 @@ int damon_start(struct damon_ctx **ctxs, int nr_ctxs, bool exclusive)
 
 	for (i = 0; i < nr_ctxs; i++) {
 		err = __damon_start(ctxs[i]);
-		if (err) {
-			damon_stop(ctxs, i);
+		if (err)
 			break;
-		}
 		nr_running_ctxs++;
 	}
 	if (exclusive && nr_running_ctxs)
 		running_exclusive_ctxs = true;
 	mutex_unlock(&damon_lock);
 
+	if (i != nr_ctxs)
+		damon_stop(ctxs, i);
+
 	return err;
 }
 
-- 
2.47.3

