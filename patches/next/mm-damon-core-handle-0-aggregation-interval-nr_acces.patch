From: SeongJae Park <sj@kernel.org>
Date: Fri, 19 Jun 2026 12:53:18 -0700
Subject: [PATCH] mm/damon/core: handle 0 aggregation interval (nr_acceses_bp
 removal patch 1 fix)

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index fe2c6f85d28a9..9904386d608fa 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -261,10 +261,12 @@ static unsigned long damon_mvsum(unsigned long current_nr,
 unsigned int damon_nr_accesses_mvsum(struct damon_region *r,
 		struct damon_ctx *ctx)
 {
-	unsigned long sample_interval, window_len, left_window, left_window_bp;
+	unsigned long sample_interval, aggr_interval;
+	unsigned long window_len, left_window, left_window_bp;
 
 	sample_interval = ctx->attrs.sample_interval ? : 1;
-	window_len = ctx->attrs.aggr_interval / sample_interval;
+	aggr_interval = ctx->attrs.aggr_interval ? : 1;
+	window_len = aggr_interval / sample_interval;
 	left_window = ctx->next_aggregation_sis - ctx->passed_sample_intervals;
 	left_window_bp = mult_frac(left_window, 10000, window_len);
 
-- 
2.47.3

