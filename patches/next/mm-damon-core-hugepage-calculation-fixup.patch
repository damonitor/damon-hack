From: SJ Park <sj@kernel.org>
Date: Tue, 21 Jul 2026 00:01:31 -0700
Subject: [PATCH] mm/damon/core: hugepage calculation fixup

Due to per-CPU counter races, the code might read free pages larger than
total ram pages.  Also, in the corner case, returning 10000 would be
suffice.

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 18 ++++++++----------
 1 file changed, 8 insertions(+), 10 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 2eb698385c2e8..29606c992f189 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -3352,20 +3352,18 @@ static unsigned int damos_get_in_active_mem_bp(bool active_ratio)
 
 static unsigned int damos_hugepage_mem_bp(void)
 {
-	unsigned long thp, total;
+	unsigned long thp, totalram_pages, free_pages;
+
+	totalram_pages = totalram_pages();
+	free_pages = global_zone_page_state(NR_FREE_PAGES);
+
+	if (totalram_pages <= free_pages)
+		return 10000;
 
 	thp = global_node_page_state(NR_ANON_THPS) +
 				global_node_page_state(NR_SHMEM_THPS) +
 				global_node_page_state(NR_FILE_THPS);
-	total = totalram_pages() - global_zone_page_state(NR_FREE_PAGES);
-
-	/*
-	 * vmstat may lag in idle systems and lead to free pages equaling to
-	 * the total RAM in the system.
-	 */
-	if (!total)
-		return INT_MAX;
-	return mult_frac(thp, 10000, total);
+	return mult_frac(thp, 10000, totalram_pages - free);
 }
 
 static void damos_set_quota_goal_current_value(struct damon_ctx *c,
-- 
