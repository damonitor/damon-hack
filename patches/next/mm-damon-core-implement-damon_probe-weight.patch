From: SJ Park <sj@kernel.org>
Date: Wed, 24 Jun 2026 20:28:40 -0700
Subject: [PATCH] mm/damon/core: implement damon_probe->weight

Signed-off-by: SJ Park <sj@kernel.org>
---
 include/linux/damon.h | 1 +
 mm/damon/core.c       | 1 +
 2 files changed, 2 insertions(+)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index 3a5c1d137b7b2..29ef713de61e6 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -855,6 +855,7 @@ struct damon_filter {
  * struct damon_probe - Data region attribute probe.
  */
 struct damon_probe {
+	unsigned int weight;
 /* private: */
 	/* Preparation actions to apply to each probing memory. */
 	struct list_head preps;
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 82574c2312623..ef6f2e0581296 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -218,6 +218,7 @@ struct damon_probe *damon_new_probe(void)
 	p = kmalloc_obj(*p);
 	if (!p)
 		return NULL;
+	p->weight = 0;
 	INIT_LIST_HEAD(&p->preps);
 	INIT_LIST_HEAD(&p->filters);
 	INIT_LIST_HEAD(&p->list);
-- 
2.47.3

