From: SeongJae Park <sj@kernel.org>
Date: Sat, 18 Apr 2026 11:55:51 -0700
Subject: [PATCH] mm/damon/core: initialize region->attr_counts in
 damon_new_region()

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index eb6ec8f612e61..97bd53015c27b 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -135,6 +135,7 @@ static void damon_verify_new_region(unsigned long start, unsigned long end)
 struct damon_region *damon_new_region(unsigned long start, unsigned long end)
 {
 	struct damon_region *region;
+	int i;
 
 	damon_verify_new_region(start, end);
 	region = kmem_cache_alloc(damon_region_cache, GFP_KERNEL);
@@ -145,6 +146,8 @@ struct damon_region *damon_new_region(unsigned long start, unsigned long end)
 	region->ar.end = end;
 	region->nr_accesses = 0;
 	region->nr_accesses_bp = 0;
+	for (i = 0; i < DAMON_MAX_DATA_ATTRS; i++)
+		region->attr_counts[i] = 0;
 	INIT_LIST_HEAD(&region->list);
 
 	region->age = 0;
-- 
2.47.3

