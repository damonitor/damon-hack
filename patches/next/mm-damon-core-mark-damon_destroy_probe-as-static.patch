From: SeongJae Park <sj@kernel.org>
Date: Sat, 25 Apr 2026 11:40:08 -0700
Subject: [PATCH] mm/damon/core: mark damon_destroy_probe() as static

It is not really being used outside of core.

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h | 1 -
 mm/damon/core.c       | 2 +-
 2 files changed, 1 insertion(+), 2 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index eb808974cf274..4266fcb121a33 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -984,7 +984,6 @@ void damon_add_filter(struct damon_probe *probe, struct damon_filter *f);
 
 struct damon_probe *damon_new_probe(void);
 void damon_add_probe(struct damon_ctx *ctx, struct damon_probe *probe);
-void damon_destroy_probe(struct damon_probe *probe);
 
 struct damon_region *damon_new_region(unsigned long start, unsigned long end);
 
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 1302e578f18cb..54834b74efef4 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -188,7 +188,7 @@ static void damon_free_probe(struct damon_probe *p)
 	kfree(p);
 }
 
-void damon_destroy_probe(struct damon_probe *p)
+static void damon_destroy_probe(struct damon_probe *p)
 {
 	damon_del_probe(p);
 	damon_free_probe(p);
-- 
2.47.3

