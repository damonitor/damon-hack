From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 14:27:12 -0700
Subject: [PATCH] mm/damon/core: move max_merge_score into the loop

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 99996abe7d908..f9c81dc44a4ce 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -4136,7 +4136,6 @@ static unsigned int kdamond_check_reported_accesses(struct damon_ctx *ctx)
 static int kdamond_fn(void *data)
 {
 	struct damon_ctx *ctx = data;
-	unsigned int max_merge_score = 0;
 	unsigned long sz_limit = 0;
 
 	pr_debug("kdamond (%d) starts\n", current->pid);
@@ -4171,6 +4170,7 @@ static int kdamond_fn(void *data)
 		unsigned long sample_interval = ctx->attrs.sample_interval;
 		bool access_check_disabled = damon_has_probe_weights(ctx);
 		bool has_prep = damon_has_prep(ctx);
+		unsigned int max_merge_score = 0;
 
 		if (kdamond_wait_activation(ctx))
 			break;
-- 
2.47.3

