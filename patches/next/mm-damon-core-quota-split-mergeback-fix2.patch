From: SeongJae Park <sj@kernel.org>
Date: Thu, 9 Apr 2026 18:15:36 -0700
Subject: [PATCH] mm/damon/core: quota-split mergeback fix2

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 22 ++++++++++------------
 1 file changed, 10 insertions(+), 12 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 17d6676f125ef..9aa3db29afee5 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -2165,29 +2165,27 @@ static void damos_apply_target(struct damon_ctx *c, struct damon_target *t)
 	unsigned long orig_end_addr;
 
 	damon_for_each_region(r, t) {
-		/*
-		 * damon_do_apply_schemes() splits the region if needed to keep
-		 * the quota.  That could result in DAMON snapshot having more
-		 * than max_nr_regions regions.
-		 *
-		 * Merge back the sliced regions to the original region if it
-		 * makes sense, as soon as the schemes-handling of the slice is
-		 * completed.
-		 */
 		if (!orig_region || orig_end_addr <= r->ar.start) {
 			orig_region = r;
 			orig_end_addr = r->ar.end;
 		}
 		damon_do_apply_schemes(c, t, r);
+		/*
+		 * damon_do_apply_schemes() splits the region if needed to keep
+		 * the quota.  Merge back the sliced regions to the original
+		 * region if there is no reason to keep the slice.
+		 */
 		if (r == orig_region)
 			continue;
 		/*
 		 * If no scheme was applied to the sliced region, the age of
-		 * the slice ain't be reset.  Don't merge that back, since that
-		 * loses the monitored access pattern information.
+		 * the slice ain't be reset.  Don't merge that back, since
+		 * otherwise the monitored information will be lost.
 		 */
-		if (r->age)
+		if (r->age) {
+			orig_region = NULL;
 			continue;
+		}
 		orig_region->ar.end = r->ar.end;
 		damon_destroy_region(r, t);
 		r = orig_region;
-- 
2.47.3

