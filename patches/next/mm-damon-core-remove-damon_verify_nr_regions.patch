From: SeongJae Park <sj@kernel.org>
Date: Sun, 8 Mar 2026 14:37:46 -0700
Subject: [PATCH] mm/damon/core: remove damon_verify_nr_regions()

damon_nr_regions() is called for each region in
kdamond_reset_aggregated() and damos_apply_scheme().  Maybe it could
impose too much overhead when there are large number of regions.  Now
damon_verify_merged_regions() does damon_nr_regions() verification per
aggregation interval.  That should be suffice.  Remove
damon_nr_regions() verification.

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 19 -------------------
 1 file changed, 19 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 09e77c53c9e94..315dfcd301ed4 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -590,27 +590,8 @@ void damon_destroy_target(struct damon_target *t, struct damon_ctx *ctx)
 	damon_free_target(t);
 }
 
-#ifdef CONFIG_DAMON_DEBUG_SANITY
-static void damon_verify_nr_regions(struct damon_target *t)
-{
-	struct damon_region *r;
-	unsigned int count = 0;
-
-	damon_for_each_region(r, t)
-		count++;
-	WARN_ONCE(count != t->nr_regions, "t->nr_regions (%u) != count (%u)\n",
-			t->nr_regions, count);
-}
-#else
-static void damon_verify_nr_regions(struct damon_target *t)
-{
-}
-#endif
-
 unsigned int damon_nr_regions(struct damon_target *t)
 {
-	damon_verify_nr_regions(t);
-
 	return t->nr_regions;
 }
 
-- 
2.47.3

