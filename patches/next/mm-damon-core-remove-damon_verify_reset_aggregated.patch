From: SeongJae Park <sj@kernel.org>
Date: Sun, 7 Jun 2026 15:56:43 -0700
Subject: [PATCH] mm/damon/core: remove damon_verify_reset_aggregated()

It is for validting nr_accesses_bp.  nr_accesse_bp is no more being
used, so don't care if it is valid.

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c | 18 ------------------
 1 file changed, 18 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 1adc882e8bddc..18b5f2602f962 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -2231,23 +2231,6 @@ void damon_report_page_fault(struct vm_fault *vmf, bool huge_pmd)
 }
 #endif
 
-#ifdef CONFIG_DAMON_DEBUG_SANITY
-static void damon_verify_reset_aggregated(struct damon_region *r,
-		struct damon_ctx *c)
-{
-	WARN_ONCE(r->nr_accesses_bp != r->last_nr_accesses * 10000,
-			"nr_accesses_bp %u last_nr_accesses %u sis %lu %lu\n",
-			r->nr_accesses_bp, r->last_nr_accesses,
-			c->passed_sample_intervals, c->next_aggregation_sis);
-}
-#else
-static void damon_verify_reset_aggregated(struct damon_region *r,
-		struct damon_ctx *c)
-{
-}
-#endif
-
-
 /*
  * Reset the aggregated monitoring results ('nr_accesses' of each region).
  */
@@ -2278,7 +2261,6 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 				r->last_probe_hits[i] = r->probe_hits[i];
 				r->probe_hits[i] = 0;
 			}
-			damon_verify_reset_aggregated(r, c);
 		}
 		ti++;
 	}
-- 
2.47.3

