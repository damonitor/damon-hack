From: SeongJae Park <sj@kernel.org>
Date: Sun, 7 Jun 2026 15:53:10 -0700
Subject: [PATCH] mm/damon/core: rename damon_moving_sum_nr() to damon__mvsum()

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/core.c             | 4 ++--
 mm/damon/tests/core-kunit.h | 6 +++---
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index 55034432dbcea..c597d0378392f 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -217,7 +217,7 @@ static struct damon_probe *damon_nth_probe(int n, struct damon_ctx *ctx)
 	return NULL;
 }
 
-static unsigned long damon_moving_sum_nr(unsigned long current_nr,
+static unsigned long damon_mvsum(unsigned long current_nr,
 		unsigned long last_nr, unsigned long left_window_bp)
 {
 	return current_nr + mult_frac(last_nr, left_window_bp, 10000);
@@ -233,7 +233,7 @@ unsigned int damon_nr_accesses_mvsum(struct damon_region *r,
 	left_window = ctx->next_aggregation_sis - ctx->passed_sample_intervals;
 	left_window_bp = mult_frac(left_window, 10000, window_len);
 
-	return damon_moving_sum_nr(r->nr_accesses, r->last_nr_accesses,
+	return damon_mvsum(r->nr_accesses, r->last_nr_accesses,
 			left_window_bp);
 }
 
diff --git a/mm/damon/tests/core-kunit.h b/mm/damon/tests/core-kunit.h
index 6202eedbd8e25..6fd63a763f3c4 100644
--- a/mm/damon/tests/core-kunit.h
+++ b/mm/damon/tests/core-kunit.h
@@ -623,7 +623,7 @@ static void damon_test_moving_sum(struct kunit *test)
 	}
 }
 
-static void damon_test_moving_sum_nr(struct kunit *test)
+static void damon_test_mvsum(struct kunit *test)
 {
 	unsigned long input_expects[] = {
 		3, 10, 5000, 8,		/* 3 + 10 * 0.5 */
@@ -637,7 +637,7 @@ static void damon_test_moving_sum_nr(struct kunit *test)
 		unsigned long left_window_bp = input_expects[i + 2];
 		unsigned long expect = input_expects[i + 3];
 
-		KUNIT_EXPECT_EQ(test, damon_moving_sum_nr(current_nr, last_nr,
+		KUNIT_EXPECT_EQ(test, damon_mvsum(current_nr, last_nr,
 					left_window_bp), expect);
 	}
 }
@@ -1520,7 +1520,7 @@ static struct kunit_case damon_test_cases[] = {
 	KUNIT_CASE(damon_test_update_monitoring_result),
 	KUNIT_CASE(damon_test_set_attrs),
 	KUNIT_CASE(damon_test_moving_sum),
-	KUNIT_CASE(damon_test_moving_sum_nr),
+	KUNIT_CASE(damon_test_mvsum),
 	KUNIT_CASE(damos_test_new_filter),
 	KUNIT_CASE(damos_test_commit_quota_goal),
 	KUNIT_CASE(damos_test_commit_quota_goals),
-- 
2.47.3

