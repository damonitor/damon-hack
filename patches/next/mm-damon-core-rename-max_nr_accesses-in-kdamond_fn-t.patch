From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 18:13:03 -0700
Subject: [PATCH] mm/damon/core: rename max_nr_accesses in kdamond_fn() to
 max_merge_score

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index ca5c3f3e45fc6..c79d17f3997b1 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -3629,7 +3629,6 @@ static void kdamond_init_ctx(struct damon_ctx *ctx)
 static int kdamond_fn(void *data)
 {
 	struct damon_ctx *ctx = data;
-	unsigned int max_nr_accesses = 0;
 	unsigned long sz_limit = 0;
 
 	pr_debug("kdamond (%d) starts\n", current->pid);
@@ -3662,6 +3661,7 @@ static int kdamond_fn(void *data)
 		unsigned long next_aggregation_sis = ctx->next_aggregation_sis;
 		unsigned long next_ops_update_sis = ctx->next_ops_update_sis;
 		unsigned long sample_interval = ctx->attrs.sample_interval;
+		unsigned int max_merge_score = 0;
 
 		if (kdamond_wait_activation(ctx))
 			break;
@@ -3673,14 +3673,13 @@ static int kdamond_fn(void *data)
 		ctx->passed_sample_intervals++;
 
 		if (ctx->ops.check_accesses)
-			max_nr_accesses = ctx->ops.check_accesses(ctx);
+			max_merge_score = ctx->ops.check_accesses(ctx);
 		if (ctx->ops.apply_probes)
 			ctx->ops.apply_probes(ctx);
 
 		if (time_after_eq(ctx->passed_sample_intervals,
 					next_aggregation_sis)) {
-			kdamond_merge_regions(ctx,
-					max_nr_accesses / 10,
+			kdamond_merge_regions(ctx, max_merge_score / 10,
 					sz_limit);
 			/* online updates might be made */
 			sz_limit = damon_apply_min_nr_regions(ctx);
-- 
2.47.3

