From: SeongJae Park <sj@kernel.org>
Date: Sat, 16 May 2026 10:19:27 -0700
Subject: [PATCH] mm/damon: (fixup) rename damon_aggregated_v2 to
 damon_aggregated_region

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/trace/events/damon.h | 2 +-
 mm/damon/core.c              | 6 +++---
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/include/trace/events/damon.h b/include/trace/events/damon.h
index 2b96a03876034..78388538acf44 100644
--- a/include/trace/events/damon.h
+++ b/include/trace/events/damon.h
@@ -130,7 +130,7 @@ TRACE_EVENT(damon_monitor_intervals_tune,
 	TP_printk("sample_us=%lu", __entry->sample_us)
 );
 
-TRACE_EVENT_CONDITION(damon_aggregated_v2,
+TRACE_EVENT_CONDITION(damon_region_aggregated,
 
 	TP_PROTO(unsigned int target_id, struct damon_region *r,
 		unsigned int nr_regions, unsigned int nr_probes),
diff --git a/mm/damon/core.c b/mm/damon/core.c
index a372397d7d6a9..5ba7ad4df4351 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -1911,7 +1911,7 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 	unsigned int nr_probes = 0;
 	struct damon_probe *probe;
 
-	if (trace_damon_aggregated_v2_enabled()) {
+	if (trace_damon_region_aggregated_enabled()) {
 		damon_for_each_probe(probe, c)
 			nr_probes++;
 	}
@@ -1923,8 +1923,8 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 			int i;
 
 			trace_damon_aggregated(ti, r, damon_nr_regions(t));
-			trace_damon_aggregated_v2(ti, r, damon_nr_regions(t),
-					nr_probes);
+			trace_damon_region_aggregated(ti, r,
+					damon_nr_regions(t), nr_probes);
 			damon_warn_fix_nr_accesses_corruption(r);
 			r->last_nr_accesses = r->nr_accesses;
 			r->nr_accesses = 0;
-- 
2.47.3

