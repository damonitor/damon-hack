From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 15:00:07 -0700
Subject: [PATCH] mm/damon: optimize max_wsum get overhead

Signed-off-by: SJ Park <sj@kernel.org>
---
 include/linux/damon.h |  2 +-
 mm/damon/core.c       | 13 ++++++++++---
 mm/damon/paddr.c      |  8 ++++----
 3 files changed, 15 insertions(+), 8 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index 32c184bbc9f80..f45d01e5e8032 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -666,7 +666,7 @@ struct damon_operations {
 	void (*prepare_access_checks)(struct damon_ctx *context);
 	unsigned int (*check_accesses)(struct damon_ctx *context);
 	unsigned int (*apply_probes)(struct damon_ctx *context,
-			bool set_samples);
+			bool set_samples, bool return_max_wsum);
 	int (*get_scheme_score)(struct damon_ctx *context,
 			struct damon_region *r, struct damos *scheme);
 	unsigned long (*apply_scheme)(struct damon_ctx *context,
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 08e469ec83a30..001233659a5f1 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -3712,7 +3712,8 @@ static int kdamond_fn(void *data)
 		unsigned long next_ops_update_sis = ctx->next_ops_update_sis;
 		unsigned long sample_interval = ctx->attrs.sample_interval;
 		bool access_check_disabled = damon_has_probe_weights(ctx);
-		unsigned int max_merge_score = 0, wsum
+		unsigned int max_merge_score = 0, max_wsum;
+		bool get_max_wsum;
 
 		if (kdamond_wait_activation(ctx))
 			break;
@@ -3727,9 +3728,15 @@ static int kdamond_fn(void *data)
 			max_merge_score = ctx->ops.check_accesses(ctx);
 
 		if (ctx->ops.apply_probes) {
+			if (time_after_eq(ctx->passed_sample_intervals,
+						next_aggregation_sis) &&
+					access_check_disabled)
+				get_max_wsum = true;
+			else
+				get_max_wsum = false;
 			max_wsum = ctx->ops.apply_probes(ctx,
-					access_check_disabled);
-			if (access_check_disabled)
+					access_check_disabled, get_max_wsum);
+			if (get_max_wsum)
 				max_merge_score = max_wsum;
 		}
 
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index c362a2d459c9b..b85f88a7a38f4 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -167,7 +167,7 @@ static bool damon_pa_filter_pass(phys_addr_t pa, struct folio *folio,
 }
 
 static unsigned int damon_pa_apply_probes(struct damon_ctx *ctx,
-		bool set_samples)
+		bool set_samples, bool return_max_wsum)
 {
 	struct damon_target *t;
 	struct damon_region *r;
@@ -193,9 +193,9 @@ static unsigned int damon_pa_apply_probes(struct damon_ctx *ctx,
 			}
 			if (folio)
 				folio_put(folio);
-			max_wsum = max(damon_probe_hits_wsum(r, false, ctx),
-					max_wsum);
-
+			if (return_max_wsum)
+				max_wsum = max(damon_probe_hits_wsum(r, false,
+							ctx), max_wsum);
 		}
 	}
 	return max_wsum;
-- 
2.47.3

