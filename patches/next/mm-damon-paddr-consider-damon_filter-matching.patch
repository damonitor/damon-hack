From: SeongJae Park <sj@kernel.org>
Date: Sun, 10 May 2026 13:46:07 -0700
Subject: [PATCH] mm/damon/paddr: consider damon_filter->matching

It is ignored now.  Fix it.

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/paddr.c | 27 ++++++++++++++++++++-------
 1 file changed, 20 insertions(+), 7 deletions(-)

diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index e160bd9c2ec43..e60af2cbc1089 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -120,6 +120,25 @@ static unsigned int damon_pa_check_accesses(struct damon_ctx *ctx)
 	return max_nr_accesses;
 }
 
+static bool damon_pa_filter_match(struct damon_filter *filter,
+		struct folio *folio)
+{
+	bool matched = false;
+
+	switch (filter->type) {
+	case DAMON_FILTER_TYPE_ANON:
+		if (!folio) {
+			matched = false;
+			break;
+		}
+		matched = folio_test_anon(folio);
+		break;
+	default:
+		break;
+	}
+	return matched == filter->matching;
+}
+
 static bool damon_pa_filter_pass(phys_addr_t pa, struct damon_probe *p)
 {
 	struct damon_filter *f;
@@ -128,13 +147,7 @@ static bool damon_pa_filter_pass(phys_addr_t pa, struct damon_probe *p)
 
 	folio = damon_get_folio(PHYS_PFN(pa));
 	damon_for_each_filter(f, p) {
-		bool matched = false;
-
-		if (f->type == DAMON_FILTER_TYPE_ANON) {
-			if (folio)
-				matched = folio_test_anon(folio);
-		}
-		if (matched) {
+		if (damon_pa_filter_match(f, folio)) {
 			pass = f->allow;
 			break;
 		}
-- 
2.47.3

