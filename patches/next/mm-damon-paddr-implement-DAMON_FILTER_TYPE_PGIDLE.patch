From: SeongJae Park <sj@kernel.org>
Date: Mon, 22 Jun 2026 20:37:20 -0700
Subject: [PATCH] mm/damon/paddr: implement DAMON_FILTER_TYPE_PGIDLE

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/paddr.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index f3cafcca08485..a4d8ca41e5c91 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -211,6 +211,12 @@ static bool damon_pa_filter_match(struct damon_filter *filter,
 			matched = filter->memcg_id == mem_cgroup_id(memcg);
 		rcu_read_unlock();
 		break;
+	case DAMON_FILTER_TYPE_PGIDLE:
+		if (!folio)
+			matched = true;
+		else
+			matched = !damon_folio_young(folio);
+		break;
 	default:
 		break;
 	}
-- 
2.47.3

