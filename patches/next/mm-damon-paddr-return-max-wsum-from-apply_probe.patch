From: SJ Park <sj@kernel.org>
Date: Sat, 4 Jul 2026 14:26:03 -0700
Subject: [PATCH] mm/damon/paddr: return max wsum from apply_probe()

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/paddr.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index 422f493c72c1c..ae7bf371991d7 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -265,6 +265,7 @@ static unsigned int damon_pa_apply_probes(struct damon_ctx *ctx,
 	struct damon_target *t;
 	struct damon_region *r;
 	struct damon_probe *p;
+	unsigned int max_wsum = 0;
 
 	damon_for_each_target(t, ctx) {
 		damon_for_each_region(r, t) {
@@ -285,10 +286,12 @@ static unsigned int damon_pa_apply_probes(struct damon_ctx *ctx,
 			}
 			if (folio)
 				folio_put(folio);
+			max_wsum = max(damon_probe_hits_wsum(r, false, ctx),
+					max_wsum);
 
 		}
 	}
-	return 0;
+	return max_wsum;
 }
 
 /*
