From: SeongJae Park <sj@kernel.org>
Date: Tue, 9 Jun 2026 22:33:39 -0700
Subject: [PATCH] mm/damon/reclaaim: ignore damon_stop() return value

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/reclaim.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/mm/damon/reclaim.c b/mm/damon/reclaim.c
index 1f0319bfa0788..0ae2eefbb9423 100644
--- a/mm/damon/reclaim.c
+++ b/mm/damon/reclaim.c
@@ -334,8 +334,10 @@ static int damon_reclaim_turn(bool on)
 {
 	int err;
 
-	if (!on)
-		return damon_stop(&ctx, 1);
+	if (!on) {
+		damon_stop(&ctx, 1);
+		return 0;
+	}
 
 	err = damon_reclaim_apply_parameters();
 	if (err)
-- 
2.47.3

