From: SeongJae Park <sj@kernel.org>
Date: Tue, 21 Apr 2026 17:55:52 -0700
Subject: [PATCH] mm/damon: rename DAMON_MAX_ATTR_COUNTS to DAMON_MAX_COUNTERS

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h    | 6 +++---
 mm/damon/core.c          | 4 ++--
 mm/damon/sysfs-schemes.c | 6 +++---
 3 files changed, 8 insertions(+), 8 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index dcc68d3c32e94..5217f0a7c376a 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -16,8 +16,8 @@
 
 /* Minimal region size.  Every damon_region is aligned by this. */
 #define DAMON_MIN_REGION_SZ	PAGE_SIZE
-/* Maximum number of data attributes that can be monitored. */
-#define DAMON_MAX_DATA_ATTRS	(4)
+/* Maximum number of monitoring counters. */
+#define DAMON_MAX_COUNTERS	(4)
 /* Max priority score for DAMON-based operation schemes */
 #define DAMOS_MAX_SCORE		(99)
 
@@ -83,7 +83,7 @@ struct damon_region {
 	unsigned long sampling_addr;
 	unsigned int nr_accesses;
 	unsigned int nr_accesses_bp;
-	unsigned char attr_counts[DAMON_MAX_DATA_ATTRS];
+	unsigned char attr_counts[DAMON_MAX_COUNTERS];
 	struct list_head list;
 
 	unsigned int age;
diff --git a/mm/damon/core.c b/mm/damon/core.c
index aeef65107ac1a..627c8823f6f24 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -243,7 +243,7 @@ struct damon_region *damon_new_region(unsigned long start, unsigned long end)
 	region->ar.end = end;
 	region->nr_accesses = 0;
 	region->nr_accesses_bp = 0;
-	for (i = 0; i < DAMON_MAX_DATA_ATTRS; i++)
+	for (i = 0; i < DAMON_MAX_COUNTERS; i++)
 		region->attr_counts[i] = 0;
 	INIT_LIST_HEAD(&region->list);
 
@@ -2155,7 +2155,7 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 			damon_warn_fix_nr_accesses_corruption(r);
 			r->last_nr_accesses = r->nr_accesses;
 			r->nr_accesses = 0;
-			for (i = 0; i < DAMON_MAX_DATA_ATTRS; i++)
+			for (i = 0; i < DAMON_MAX_COUNTERS; i++)
 				r->attr_counts[i] = 0;
 			damon_verify_reset_aggregated(r, c);
 		}
diff --git a/mm/damon/sysfs-schemes.c b/mm/damon/sysfs-schemes.c
index f13de377422d7..7a43ebbd900fe 100644
--- a/mm/damon/sysfs-schemes.c
+++ b/mm/damon/sysfs-schemes.c
@@ -20,7 +20,7 @@ struct damon_sysfs_scheme_region {
 	unsigned int nr_accesses;
 	unsigned int age;
 	unsigned long sz_filter_passed;
-	unsigned char attr_counts[DAMON_MAX_DATA_ATTRS];
+	unsigned char attr_counts[DAMON_MAX_COUNTERS];
 	struct list_head list;
 };
 
@@ -98,10 +98,10 @@ static ssize_t attr_counts_show(struct kobject *kobj,
 	str = kcalloc(2048, sizeof(*str), GFP_KERNEL);
 	if (!str)
 		return -ENOMEM;
-	for (i = 0; i < DAMON_MAX_DATA_ATTRS; i++) {
+	for (i = 0; i < DAMON_MAX_COUNTERS; i++) {
 		snprintf(&str[strlen(str)], 2048 - strlen(str), "%hhu",
 				region->attr_counts[i]);
-		if (i < DAMON_MAX_DATA_ATTRS - 1)
+		if (i < DAMON_MAX_COUNTERS - 1)
 			snprintf(&str[strlen(str)], 2048 - strlen(str), ",");
 	}
 	ret = sysfs_emit(buf, "%s\n", str);
-- 
2.47.3

