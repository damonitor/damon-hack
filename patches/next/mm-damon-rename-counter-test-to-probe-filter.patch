From: SeongJae Park <sj@kernel.org>
Date: Thu, 23 Apr 2026 07:44:21 -0700
Subject: [PATCH] mm/damon: rename counter/test  to probe/filter

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 Documentation/admin-guide/mm/damon/usage.rst |   4 +-
 include/linux/damon.h                        |  72 ++--
 include/trace/events/damon.h                 |  21 +-
 mm/damon/core.c                              | 170 ++++-----
 mm/damon/paddr.c                             |  24 +-
 mm/damon/sysfs-schemes.c                     |  22 +-
 mm/damon/sysfs.c                             | 379 ++++++++++---------
 7 files changed, 347 insertions(+), 345 deletions(-)

diff --git a/Documentation/admin-guide/mm/damon/usage.rst b/Documentation/admin-guide/mm/damon/usage.rst
index a38e12759101b..cfd7738e40234 100644
--- a/Documentation/admin-guide/mm/damon/usage.rst
+++ b/Documentation/admin-guide/mm/damon/usage.rst
@@ -75,7 +75,7 @@ comma (",").
     │ │ │ │ │ │ sample/filters/nr_filters
     │ │ │ │ │ │ │ 0/type,matching,allow,cpumask,tid_arr
     │ │ │ │ │ │ nr_regions/min,max
-    │ │ │ │ │ data_attrs/nr_attrs
+    │ │ │ │ │ probes/nr_probes
     │ │ │ │ │ │ 0/filters/nr_filters
     │ │ │ │ │ │ │ │ 0/type,matching,allow
     │ │ │ │ │ │ │ │ ...
@@ -106,7 +106,7 @@ comma (",").
     │ │ │ │ │ │ │ :ref:`stats <sysfs_schemes_stats>`/nr_tried,sz_tried,nr_applied,sz_applied,sz_ops_filter_passed,qt_exceeds,nr_snapshots,max_nr_snapshots
     │ │ │ │ │ │ │ :ref:`tried_regions <sysfs_schemes_tried_regions>`/total_bytes
     │ │ │ │ │ │ │ │ 0/start,end,nr_accesses,age,sz_filter_passed,
-    │ │ │ │ │ │ │ │     data_attr_positives
+    │ │ │ │ │ │ │ │     probe_hits
     │ │ │ │ │ │ │ │ ...
     │ │ │ │ │ │ ...
     │ │ │ │ ...
diff --git a/include/linux/damon.h b/include/linux/damon.h
index 9f3250164c063..866deac10361f 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -16,8 +16,8 @@
 
 /* Minimal region size.  Every damon_region is aligned by this. */
 #define DAMON_MIN_REGION_SZ	PAGE_SIZE
-/* Maximum number of monitoring counters. */
-#define DAMON_MAX_COUNTERS	(4)
+/* Maximum number of monitoring probes. */
+#define DAMON_MAX_PROBES	(4)
 /* Max priority score for DAMON-based operation schemes */
 #define DAMOS_MAX_SCORE		(99)
 
@@ -54,7 +54,7 @@ struct damon_size_range {
  * @nr_accesses:	Access frequency of this region.
  * @nr_accesses_bp:	@nr_accesses in basis point (0.01%) that updated for
  *			each sampling interval.
- * @counts:		Values of each monitoring counter.
+ * @probe_hits:		Number of probe-positive region samples.
  * @list:		List head for siblings.
  * @age:		Age of this region.
  *
@@ -83,7 +83,7 @@ struct damon_region {
 	unsigned long sampling_addr;
 	unsigned int nr_accesses;
 	unsigned int nr_accesses_bp;
-	unsigned char counts[DAMON_MAX_COUNTERS];
+	unsigned char probe_hits[DAMON_MAX_PROBES];
 	struct list_head list;
 
 	unsigned int age;
@@ -688,7 +688,7 @@ enum damon_ops_id {
  * @update:			Update operations-related data structures.
  * @prepare_access_checks:	Prepare next access check of target regions.
  * @check_accesses:		Check the accesses to target regions.
- * @test_counters:		Run counter tests for each region.
+ * @apply_probes:		Apply probes for each region.
  * @get_scheme_score:		Get the score of a region for a scheme.
  * @apply_scheme:		Apply a DAMON-based operation scheme.
  * @target_valid:		Determine if the target is valid.
@@ -732,7 +732,7 @@ struct damon_operations {
 	void (*update)(struct damon_ctx *context);
 	void (*prepare_access_checks)(struct damon_ctx *context);
 	unsigned int (*check_accesses)(struct damon_ctx *context);
-	void (*test_counters)(struct damon_ctx *context);
+	void (*apply_probes)(struct damon_ctx *context);
 	int (*get_scheme_score)(struct damon_ctx *context,
 			struct damon_region *r, struct damos *scheme);
 	unsigned long (*apply_scheme)(struct damon_ctx *context,
@@ -795,37 +795,37 @@ struct damon_intervals_goal {
 };
 
 /**
- * enum damon_test_type - Type of memory for &struct damon_test
+ * enum damon_filter_type - Type of &struct damon_filter
  *
  * @DAMON_TEST_TYPE_ANON:	Anonymous pages.
  */
-enum damon_test_type {
+enum damon_filter_type {
 	DAMON_TEST_TYPE_ANON,
 };
 
 /**
- * struct damon_test - Data attribute test.
+ * struct damon_filter - DAMON region filter for &struct damon_probe.
  *
- * @type:	Type of the attribute.
+ * @type:	Type of the region.
  * @matcing:	Whether this filter is for the type-matching ones.
- * @pass:	Whether the @type-@matching ones should pass this test.
- * @list:	Sinblings list.
+ * @allow:	Whether the @type-@matching ones should pass this filter.
+ * @list:	Siblings list.
  */
-struct damon_test {
-	enum damon_test_type type;
+struct damon_filter {
+	enum damon_filter_type type;
 	bool matching;
-	bool pass;
+	bool allow;
 	struct list_head list;
 };
 
 /**
- * struct damon_counter - Data attribute counter.
+ * struct damon_probe - Data region attribute probe.
  *
- * @tests:	Tests for confirming the attribute.
- * @list:	List for siblings.
+ * @filters:	Filters for assessing if a given region is for this probe.
+ * @list:	Siblings list.
  */
-struct damon_counter {
-	struct list_head tests;
+struct damon_probe {
+	struct list_head filters;
 	struct list_head list;
 };
 
@@ -1023,7 +1023,7 @@ struct damon_ctx {
 
 /* public: */
 	struct damon_operations ops;
-	struct list_head counters;
+	struct list_head probes;
 	struct damon_sample_control sample_control;
 	unsigned long addr_unit;
 	unsigned long min_region_sz;
@@ -1058,17 +1058,17 @@ static inline unsigned long damon_sz_region(struct damon_region *r)
 	return r->ar.end - r->ar.start;
 }
 
-#define damon_for_each_test(t, a) \
-	list_for_each_entry(t, &a->tests, list)
+#define damon_for_each_filter(f, p) \
+	list_for_each_entry(f, &p->filters, list)
 
-#define damon_for_each_test_safe(t, next, a) \
-	list_for_each_entry_safe(t, next, &a->tests, list)
+#define damon_for_each_filter_safe(f, next, p) \
+	list_for_each_entry_safe(f, next, &p->filters, list)
 
-#define damon_for_each_counter(c, ctx) \
-	list_for_each_entry(c, &ctx->counters, list)
+#define damon_for_each_probe(p, ctx) \
+	list_for_each_entry(p, &ctx->probes, list)
 
-#define damon_for_each_counter_safe(c, next, ctx) \
-	list_for_each_entry_safe(c, next, &ctx->counters, list)
+#define damon_for_each_probe_safe(p, next, ctx) \
+	list_for_each_entry_safe(p, next, &ctx->probes, list)
 
 #define damon_for_each_region(r, t) \
 	list_for_each_entry(r, &t->regions_list, list)
@@ -1117,14 +1117,14 @@ static inline unsigned long damon_sz_region(struct damon_region *r)
 
 #ifdef CONFIG_DAMON
 
-struct damon_test *damon_new_test(enum damon_test_type type,
-		bool matching, bool pass);
-void damon_add_test(struct damon_counter *counter, struct damon_test *t);
-void damon_destroy_test(struct damon_test *t);
+struct damon_filter *damon_new_filter(enum damon_filter_type type,
+		bool matching, bool allow);
+void damon_add_filter(struct damon_probe *probe, struct damon_filter *f);
+void damon_destroy_filter(struct damon_filter *filter);
 
-struct damon_counter *damon_new_counter(void);
-void damon_add_counter(struct damon_ctx *ctx, struct damon_counter *counter);
-void damon_destroy_counter(struct damon_counter *c);
+struct damon_probe *damon_new_probe(void);
+void damon_add_probe(struct damon_ctx *ctx, struct damon_probe *probe);
+void damon_destroy_probe(struct damon_probe *probe);
 
 struct damon_region *damon_new_region(unsigned long start, unsigned long end);
 
diff --git a/include/trace/events/damon.h b/include/trace/events/damon.h
index b340115c3a5cf..121d7bc3a2c27 100644
--- a/include/trace/events/damon.h
+++ b/include/trace/events/damon.h
@@ -144,10 +144,10 @@ TRACE_EVENT(damon_aggregated_v2,
 		__field(unsigned long, end)
 		__field(unsigned int, nr_accesses)
 		__field(unsigned int, age)
-		__field(unsigned char, count0)
-		__field(unsigned char, count1)
-		__field(unsigned char, count2)
-		__field(unsigned char, count3)
+		__field(unsigned char, probe_hit0)
+		__field(unsigned char, probe_hit1)
+		__field(unsigned char, probe_hit2)
+		__field(unsigned char, probe_hit3)
 	),
 
 	TP_fast_assign(
@@ -157,17 +157,18 @@ TRACE_EVENT(damon_aggregated_v2,
 		__entry->end = r->ar.end;
 		__entry->nr_accesses = r->nr_accesses;
 		__entry->age = r->age;
-		__entry->count0 = r->counts[0];
-		__entry->count1 = r->counts[1];
-		__entry->count2 = r->counts[2];
-		__entry->count3 = r->counts[3];
+		__entry->probe_hit0 = r->probe_hits[0];
+		__entry->probe_hit1 = r->probe_hits[1];
+		__entry->probe_hit2 = r->probe_hits[2];
+		__entry->probe_hit3 = r->probe_hits[3];
 	),
 
 	TP_printk("target_id=%lu nr_regions=%u %lu-%lu: %u %u %hhu %hhu %hhu %hhu",
 			__entry->target_id, __entry->nr_regions,
 			__entry->start, __entry->end,
-			__entry->nr_accesses, __entry->age, __entry->count0,
-			__entry->count1, __entry->count2, __entry->count3)
+			__entry->nr_accesses, __entry->age,
+			__entry->probe_hit0, __entry->probe_hit1,
+			__entry->probe_hit2, __entry->probe_hit3)
 );
 
 TRACE_EVENT(damon_aggregated,
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 1d1a1e3fe09b4..0de28a1325286 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -116,99 +116,99 @@ int damon_select_ops(struct damon_ctx *ctx, enum damon_ops_id id)
 	return err;
 }
 
-struct damon_test *damon_new_test(enum damon_test_type type, bool matching,
-		bool pass)
+struct damon_filter *damon_new_filter(enum damon_filter_type type,
+		bool matching, bool allow)
 {
-	struct damon_test *test;
+	struct damon_filter *filter;
 
-	test = kmalloc_obj(*test);
-	if (!test)
+	filter = kmalloc_obj(*filter);
+	if (!filter)
 		return NULL;
-	test->type = type;
-	test->matching = matching;
-	test->pass = pass;
-	INIT_LIST_HEAD(&test->list);
-	return test;
+	filter->type = type;
+	filter->matching = matching;
+	filter->allow = allow;
+	INIT_LIST_HEAD(&filter->list);
+	return filter;
 }
 
-void damon_add_test(struct damon_counter *c, struct damon_test *t)
+void damon_add_filter(struct damon_probe *p, struct damon_filter *f)
 {
-	list_add_tail(&t->list, &c->tests);
+	list_add_tail(&f->list, &p->filters);
 }
 
-static void damon_del_test(struct damon_test *t)
+static void damon_del_filter(struct damon_filter *f)
 {
-	list_del(&t->list);
+	list_del(&f->list);
 }
 
-static void damon_free_test(struct damon_test *t)
+static void damon_free_filter(struct damon_filter *f)
 {
-	kfree(t);
+	kfree(f);
 }
 
-void damon_destroy_test(struct damon_test *t)
+void damon_destroy_filter(struct damon_filter *f)
 {
-	damon_del_test(t);
-	damon_free_test(t);
+	damon_del_filter(f);
+	damon_free_filter(f);
 }
 
-static struct damon_test *damon_nth_test(int n, struct damon_counter *c)
+static struct damon_filter *damon_nth_filter(int n, struct damon_probe *p)
 {
-	struct damon_test *t;
+	struct damon_filter *f;
 	int i = 0;
 
-	damon_for_each_test(t, c) {
+	damon_for_each_filter(f, p) {
 		if (i++ == n)
-			return t;
+			return f;
 	}
 	return NULL;
 }
 
-struct damon_counter *damon_new_counter(void)
+struct damon_probe *damon_new_probe(void)
 {
-	struct damon_counter *c;
+	struct damon_probe *p;
 
-	c = kmalloc_obj(*c);
-	if (!c)
+	p = kmalloc_obj(*p);
+	if (!p)
 		return NULL;
-	INIT_LIST_HEAD(&c->tests);
-	INIT_LIST_HEAD(&c->list);
-	return c;
+	INIT_LIST_HEAD(&p->filters);
+	INIT_LIST_HEAD(&p->list);
+	return p;
 }
 
-void damon_add_counter(struct damon_ctx *ctx, struct damon_counter *counter)
+void damon_add_probe(struct damon_ctx *ctx, struct damon_probe *probe)
 {
-	list_add_tail(&counter->list, &ctx->counters);
+	list_add_tail(&probe->list, &ctx->probes);
 }
 
-static void damon_del_counter(struct damon_counter *c)
+static void damon_del_probe(struct damon_probe *p)
 {
-	list_del(&c->list);
+	list_del(&p->list);
 }
 
-static void damon_free_counter(struct damon_counter *c)
+static void damon_free_probe(struct damon_probe *p)
 {
-	struct damon_test *t, *next;
+	struct damon_filter *f, *next;
 
-	damon_for_each_test_safe(t, next, c)
-		damon_free_test(t);
-	kfree(c);
+	damon_for_each_filter_safe(f, next, p)
+		damon_free_filter(f);
+	kfree(p);
 }
 
-void damon_destroy_counter(struct damon_counter *a)
+void damon_destroy_probe(struct damon_probe *p)
 {
-	damon_del_counter(a);
-	damon_free_counter(a);
+	damon_del_probe(p);
+	damon_free_probe(p);
 }
 
-static struct damon_counter *damon_nth_counter(int n, struct damon_ctx *ctx)
+static struct damon_probe *damon_nth_probe(int n, struct damon_ctx *ctx)
 {
-	struct damon_counter *c;
+	struct damon_probe *p;
 	int i = 0;
 
-	damon_for_each_counter(c, ctx) {
+	damon_for_each_probe(p, ctx) {
 		if (i++ == n)
-			return c;
+			return p;
 	}
 	return NULL;
 }
@@ -243,8 +243,8 @@ struct damon_region *damon_new_region(unsigned long start, unsigned long end)
 	region->ar.end = end;
 	region->nr_accesses = 0;
 	region->nr_accesses_bp = 0;
-	for (i = 0; i < DAMON_MAX_COUNTERS; i++)
-		region->counts[i] = 0;
+	for (i = 0; i < DAMON_MAX_PROBES; i++)
+		region->probe_hits[i] = 0;
 	INIT_LIST_HEAD(&region->list);
 
 	region->age = 0;
@@ -809,7 +809,7 @@ struct damon_ctx *damon_new_ctx(void)
 	ctx->attrs.min_nr_regions = 10;
 	ctx->attrs.max_nr_regions = 1000;
 
-	INIT_LIST_HEAD(&ctx->counters);
+	INIT_LIST_HEAD(&ctx->probes);
 
 	ctx->sample_control.primitives_enabled.page_table = true;
 	INIT_LIST_HEAD(&ctx->sample_control.sample_filters);
@@ -835,15 +835,15 @@ void damon_destroy_ctx(struct damon_ctx *ctx)
 {
 	struct damos *s, *next_s;
 	struct damon_sample_filter *f, *next_f;
-	struct damon_counter *c, *next_c;
+	struct damon_probe *p, *next_p;
 
 	damon_destroy_targets(ctx);
 
 	damon_for_each_scheme_safe(s, next_s, ctx)
 		damon_destroy_scheme(s);
 
-	damon_for_each_counter_safe(c, next_c, ctx)
-		damon_destroy_counter(c);
+	damon_for_each_probe_safe(p, next_p, ctx)
+		damon_destroy_probe(p);
 
 	damon_for_each_sample_filter_safe(f, next_f, &ctx->sample_control)
 		damon_destroy_sample_filter(f, &ctx->sample_control);
@@ -1533,66 +1533,66 @@ static int damon_commit_targets(
 	return 0;
 }
 
-static void damon_commit_test(struct damon_test *dst,
-		struct damon_test *src)
+static void damon_commit_filter(struct damon_filter *dst,
+		struct damon_filter *src)
 {
 	dst->type = src->type;
 	dst->matching = src->matching;
-	dst->pass = src->pass;
+	dst->allow = src->allow;
 }
 
-static int damon_commit_tests(struct damon_counter *dst,
-		struct damon_counter *src)
+static int damon_commit_filters(struct damon_probe *dst,
+		struct damon_probe *src)
 {
-	struct damon_test *dst_test, *next, *src_test, *new_test;
+	struct damon_filter *dst_filter, *next, *src_filter, *new_filter;
 	int i = 0, j = 0;
 
-	damon_for_each_test_safe(dst_test, next, dst) {
-		src_test = damon_nth_test(i++, src);
-		if (src_test)
-			damon_commit_test(dst_test, src_test);
+	damon_for_each_filter_safe(dst_filter, next, dst) {
+		src_filter = damon_nth_filter(i++, src);
+		if (src_filter)
+			damon_commit_filter(dst_filter, src_filter);
 		else
-			damon_destroy_test(dst_test);
+			damon_destroy_filter(dst_filter);
 	}
 
-	damon_for_each_test_safe(src_test, next, src) {
+	damon_for_each_filter_safe(src_filter, next, src) {
 		if (j++ < i)
 			continue;
 
-		new_test = damon_new_test(src_test->type, src_test->matching,
-				src_test->pass);
-		if (!new_test)
+		new_filter = damon_new_filter(src_filter->type,
+				src_filter->matching, src_filter->allow);
+		if (!new_filter)
 			return -ENOMEM;
-		damon_add_test(dst, new_test);
+		damon_add_filter(dst, new_filter);
 	}
 	return 0;
 }
 
-static int damon_commit_counters(struct damon_ctx *dst, struct damon_ctx *src)
+static int damon_commit_probes(struct damon_ctx *dst, struct damon_ctx *src)
 {
-	struct damon_counter *dst_counter, *next, *src_counter, *new_counter;
+	struct damon_probe *dst_probe, *next, *src_probe, *new_probe;
 	int i = 0, j = 0, err;
 
-	damon_for_each_counter_safe(dst_counter, next, dst) {
-		src_counter = damon_nth_counter(i++, src);
-		if (src_counter) {
-			err = damon_commit_tests(dst_counter, src_counter);
+	damon_for_each_probe_safe(dst_probe, next, dst) {
+		src_probe = damon_nth_probe(i++, src);
+		if (src_probe) {
+			err = damon_commit_filters(dst_probe, src_probe);
 			if (err)
 				return err;
 		} else {
-			damon_destroy_counter(dst_counter);
+			damon_destroy_probe(dst_probe);
 		}
 	}
 
-	damon_for_each_counter_safe(src_counter, next, src) {
+	damon_for_each_probe_safe(src_probe, next, src) {
 		if (j++ < i)
 			continue;
 
-		new_counter = damon_new_counter();
-		if (!new_counter)
+		new_probe = damon_new_probe();
+		if (!new_probe)
 			return -ENOMEM;
-		damon_add_counter(dst, new_counter);
-		err = damon_commit_tests(new_counter, src_counter);
+		damon_add_probe(dst, new_probe);
+		err = damon_commit_filters(new_probe, src_probe);
 		if (err)
 			return err;
 	}
@@ -1731,7 +1731,7 @@ int damon_commit_ctx(struct damon_ctx *dst, struct damon_ctx *src)
 	}
 	dst->pause = src->pause;
 	dst->ops = src->ops;
-	err = damon_commit_counters(dst, src);
+	err = damon_commit_probes(dst, src);
 	if (err)
 		return err;
 	err = damon_commit_sample_control(&dst->sample_control,
@@ -2155,8 +2155,8 @@ static void kdamond_reset_aggregated(struct damon_ctx *c)
 			damon_warn_fix_nr_accesses_corruption(r);
 			r->last_nr_accesses = r->nr_accesses;
 			r->nr_accesses = 0;
-			for (i = 0; i < DAMON_MAX_COUNTERS; i++)
-				r->counts[i] = 0;
+			for (i = 0; i < DAMON_MAX_PROBES; i++)
+				r->probe_hits[i] = 0;
 			damon_verify_reset_aggregated(r, c);
 		}
 		ti++;
@@ -3649,8 +3649,8 @@ static int kdamond_fn(void *data)
 			max_nr_accesses = kdamond_check_reported_accesses(ctx);
 		else if (ctx->ops.check_accesses)
 			max_nr_accesses = ctx->ops.check_accesses(ctx);
-		if (ctx->ops.test_counters)
-			ctx->ops.test_counters(ctx);
+		if (ctx->ops.apply_probes)
+			ctx->ops.apply_probes(ctx);
 
 		if (time_after_eq(ctx->passed_sample_intervals,
 					next_aggregation_sis)) {
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index 16f7646920a8a..aa3af7479c066 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -184,44 +184,44 @@ static unsigned int damon_pa_check_accesses(struct damon_ctx *ctx)
 	return max_nr_accesses;
 }
 
-static bool damon_pa_tests_pass(phys_addr_t pa, struct damon_counter *c)
+static bool damon_pa_filter_pass(phys_addr_t pa, struct damon_probe *p)
 {
-	struct damon_test *t;
+	struct damon_filter *f;
 	bool default_pass = true;
 
-	damon_for_each_test(t, c) {
+	damon_for_each_filter(f, p) {
 		bool matched = false;
 
-		if (t->type == DAMON_TEST_TYPE_ANON) {
+		if (f->type == DAMON_TEST_TYPE_ANON) {
 			struct folio *folio = damon_get_folio(PHYS_PFN(pa));
 
 			if (folio)
 				matched = folio_test_anon(folio);
 		}
 		if (matched)
-			return t->pass;
-		default_pass = !t->pass;
+			return f->allow;
+		default_pass = !f->allow;
 	}
