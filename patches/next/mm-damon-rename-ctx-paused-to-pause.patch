From: SeongJae Park <sj@kernel.org>
Date: Sun, 8 Mar 2026 13:35:19 -0700
Subject: [PATCH] mm/damon: rename ctx->paused to pause

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h | 2 +-
 mm/damon/core.c       | 6 +++---
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index abe6279b49727..170505f21d7ff 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -812,7 +812,7 @@ struct damon_ctx {
 	 */
 	unsigned long next_intervals_tune_sis;
 	/* pause kdamond main loop */
-	bool paused;
+	bool pause;
 	/* for waiting until the execution of the kdamond_fn is started */
 	struct completion kdamond_started;
 	/* for scheme quotas prioritization */
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 3bf312b9ccab0..d8771581a7f95 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -1363,7 +1363,7 @@ int damon_commit_ctx(struct damon_ctx *dst, struct damon_ctx *src)
 		if (err)
 			return err;
 	}
-	dst->paused = src->paused;
+	dst->pause = src->pause;
 	dst->ops = src->ops;
 	dst->addr_unit = src->addr_unit;
 	dst->min_region_sz = src->min_region_sz;
@@ -2985,9 +2985,9 @@ static int kdamond_fn(void *data)
 		unsigned long next_ops_update_sis = ctx->next_ops_update_sis;
 		unsigned long sample_interval = ctx->attrs.sample_interval;
 
-		if (ctx->paused) {
+		if (ctx->pause) {
 			kdamond_usleep(sample_interval);
-			/* allow caller resetting paused via damon_call() */
+			/* allow caller resetting pause via damon_call() */
 			kdamond_call(ctx, false);
 			continue;
 		}
-- 
2.47.3

