From: SeongJae Park <sj@kernel.org>
Date: Sun, 19 Apr 2026 17:29:07 -0700
Subject: [PATCH] mm/damon: rename data_attrs/filter to counter/test

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 include/linux/damon.h                  |  62 ++--
 mm/damon/core.c                        | 165 ++++++-----
 mm/damon/paddr.c                       |  26 +-
 mm/damon/sysfs.c                       | 388 ++++++++++++-------------
 tools/testing/selftests/damon/sysfs.sh |  46 +--
 5 files changed, 342 insertions(+), 345 deletions(-)

diff --git a/include/linux/damon.h b/include/linux/damon.h
index c97bc5f3de88a..dcc68d3c32e94 100644
--- a/include/linux/damon.h
+++ b/include/linux/damon.h
@@ -688,7 +688,7 @@ enum damon_ops_id {
  * @update:			Update operations-related data structures.
  * @prepare_access_checks:	Prepare next access check of target regions.
  * @check_accesses:		Check the accesses to target regions.
- * @check_data_attrs:		Check the data attributes of target regions.
+ * @test_counters:		Run data attribute tests of target regions.
  * @get_scheme_score:		Get the score of a region for a scheme.
  * @apply_scheme:		Apply a DAMON-based operation scheme.
  * @target_valid:		Determine if the target is valid.
@@ -732,7 +732,7 @@ struct damon_operations {
 	void (*update)(struct damon_ctx *context);
 	void (*prepare_access_checks)(struct damon_ctx *context);
 	unsigned int (*check_accesses)(struct damon_ctx *context);
-	void (*check_data_attrs)(struct damon_ctx *context);
+	void (*test_counters)(struct damon_ctx *context);
 	int (*get_scheme_score)(struct damon_ctx *context,
 			struct damon_region *r, struct damos *scheme);
 	unsigned long (*apply_scheme)(struct damon_ctx *context,
@@ -795,35 +795,37 @@ struct damon_intervals_goal {
 };
 
 /**
- * enum damon_filter_type - Type of memory for &struct damon_filter
+ * enum damon_test_type - Type of memory for &struct damon_test
  *
- * @DAMON_FILTER_TYPE_ANON:	Anonymous pages.
+ * @DAMON_TEST_TYPE_ANON:	Anonymous pages.
  */
-enum damon_filter_type {
-	DAMON_FILTER_TYPE_ANON,
+enum damon_test_type {
+	DAMON_TEST_TYPE_ANON,
 };
 
 /**
- * struct damon_filter - Data attribute filter.
+ * struct damon_test - Data attribute test.
  *
  * @type:	Type of the attribute.
  * @matcing:	Whether this filter is for the type-matching ones.
- * @allow:	Whether to allow monitoring the @type-@matching ones.
+ * @pass:	Whether the @type-@matching ones should pass this test.
+ * @list:	Sinblings list.
  */
-struct damon_filter {
-	enum damon_filter_type type;
+struct damon_test {
+	enum damon_test_type type;
 	bool matching;
-	bool allow;
+	bool pass;
 	struct list_head list;
 };
 
 /**
- * struct damon_data_attr - Data attribute to monitor.
+ * struct damon_counter - Data attribute counter.
  *
+ * @tests:	Tests for confirming the attribute.
  * @list:	List for siblings.
  */
-struct damon_data_attr {
-	struct list_head filters;
+struct damon_counter {
+	struct list_head tests;
 	struct list_head list;
 };
 
@@ -1021,7 +1023,7 @@ struct damon_ctx {
 
 /* public: */
 	struct damon_operations ops;
-	struct list_head data_attrs;
+	struct list_head counters;
 	struct damon_sample_control sample_control;
 	unsigned long addr_unit;
 	unsigned long min_region_sz;
@@ -1056,17 +1058,17 @@ static inline unsigned long damon_sz_region(struct damon_region *r)
 	return r->ar.end - r->ar.start;
 }
 
-#define damon_for_each_filter(f, a) \
-	list_for_each_entry(f, &a->filters, list)
+#define damon_for_each_test(t, a) \
+	list_for_each_entry(t, &a->tests, list)
 
-#define damon_for_each_filter_safe(f, next, a) \
-	list_for_each_entry_safe(f, next, &a->filters, list)
+#define damon_for_each_test_safe(t, next, a) \
+	list_for_each_entry_safe(t, next, &a->tests, list)
 
-#define damon_for_each_data_attr(a, ctx) \
-	list_for_each_entry(a, &ctx->data_attrs, list)
+#define damon_for_each_counter(c, ctx) \
+	list_for_each_entry(c, &ctx->counters, list)
 
-#define damon_for_each_data_attr_safe(a, next, ctx) \
-	list_for_each_entry_safe(a, next, &ctx->data_attrs, list)
+#define damon_for_each_counter_safe(c, next, ctx) \
+	list_for_each_entry_safe(c, next, &ctx->counters, list)
 
 #define damon_for_each_region(r, t) \
 	list_for_each_entry(r, &t->regions_list, list)
@@ -1115,14 +1117,14 @@ static inline unsigned long damon_sz_region(struct damon_region *r)
 
 #ifdef CONFIG_DAMON
 
-struct damon_filter *damon_new_filter(enum damon_filter_type type,
-		bool matching, bool allow);
-void damon_add_filter(struct damon_data_attr *attr, struct damon_filter *f);
-void damon_destroy_filter(struct damon_filter *f);
+struct damon_test *damon_new_test(enum damon_test_type type,
+		bool matching, bool pass);
+void damon_add_test(struct damon_counter *counter, struct damon_test *t);
+void damon_destroy_test(struct damon_test *t);
 
-struct damon_data_attr *damon_new_data_attr(void);
-void damon_add_data_attr(struct damon_ctx *c, struct damon_data_attr *a);
-void damon_destroy_data_attr(struct damon_data_attr *a);
+struct damon_counter *damon_new_counter(void);
+void damon_add_counter(struct damon_ctx *ctx, struct damon_counter *counter);
+void damon_destroy_counter(struct damon_counter *c);
 
 struct damon_region *damon_new_region(unsigned long start, unsigned long end);
 
diff --git a/mm/damon/core.c b/mm/damon/core.c
index 170987949819d..14e2119909123 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -116,101 +116,99 @@ int damon_select_ops(struct damon_ctx *ctx, enum damon_ops_id id)
 	return err;
 }
 
-struct damon_filter *damon_new_filter(enum damon_filter_type type, bool
-		matching, bool allow)
+struct damon_test *damon_new_test(enum damon_test_type type, bool matching,
+		bool pass)
 {
-	struct damon_filter *filter;
+	struct damon_test *test;
 
-	filter = kmalloc_obj(*filter);
-	if (!filter)
+	test = kmalloc_obj(*test);
+	if (!test)
 		return NULL;
-	filter->type = type;
-	filter->matching = matching;
-	filter->allow = allow;
-	INIT_LIST_HEAD(&filter->list);
-	return filter;
+	test->type = type;
+	test->matching = matching;
+	test->pass = pass;
+	INIT_LIST_HEAD(&test->list);
+	return test;
 }
 
-void damon_add_filter(struct damon_data_attr *attr, struct damon_filter *f)
+void damon_add_test(struct damon_counter *c, struct damon_test *t)
 {
-	list_add_tail(&f->list, &attr->filters);
+	list_add_tail(&t->list, &c->tests);
 }
 
-static void damon_del_filter(struct damon_filter *f)
+static void damon_del_test(struct damon_test *t)
 {
-	list_del(&f->list);
+	list_del(&t->list);
 }
 
-static void damon_free_filter(struct damon_filter *f)
+static void damon_free_test(struct damon_test *t)
 {
-	kfree(f);
+	kfree(t);
 }
 
-void damon_destroy_filter(struct damon_filter *f)
+void damon_destroy_test(struct damon_test *t)
 {
-	damon_del_filter(f);
-	damon_free_filter(f);
+	damon_del_test(t);
+	damon_free_test(t);
 }
 
-static struct damon_filter *damon_nth_filter(int n,
-		struct damon_data_attr *attr)
+static struct damon_test *damon_nth_test(int n, struct damon_counter *c)
 {
-	struct damon_filter *f;
+	struct damon_test *t;
 	int i = 0;
 
-	damon_for_each_filter(f, attr) {
+	damon_for_each_test(t, c) {
 		if (i++ == n)
-			return f;
+			return t;
 	}
 	return NULL;
 }
 
-struct damon_data_attr *damon_new_data_attr(void)
+struct damon_counter *damon_new_counter(void)
 {
-	struct damon_data_attr *a;
+	struct damon_counter *c;
 
-	a = kmalloc_obj(*a);
-	if (!a)
+	c = kmalloc_obj(*c);
+	if (!c)
 		return NULL;
-	INIT_LIST_HEAD(&a->filters);
-	INIT_LIST_HEAD(&a->list);
-	return a;
+	INIT_LIST_HEAD(&c->tests);
+	INIT_LIST_HEAD(&c->list);
+	return c;
 }
 
-void damon_add_data_attr(struct damon_ctx *c, struct damon_data_attr *a)
+void damon_add_counter(struct damon_ctx *ctx, struct damon_counter *counter)
 {
-	list_add_tail(&a->list, &c->data_attrs);
+	list_add_tail(&counter->list, &ctx->counters);
 }
 
-static void damon_del_data_attr(struct damon_data_attr *a)
+static void damon_del_counter(struct damon_counter *c)
 {
-	list_del(&a->list);
+	list_del(&c->list);
 }
 
-static void damon_free_data_attr(struct damon_data_attr *a)
+static void damon_free_counter(struct damon_counter *c)
 {
-	struct damon_filter *f, *next;
+	struct damon_test *t, *next;
 
-	damon_for_each_filter_safe(f, next, a)
-		damon_free_filter(f);
-	kfree(a);
+	damon_for_each_test_safe(t, next, c)
+		damon_free_test(t);
+	kfree(c);
 }
 
-void damon_destroy_data_attr(struct damon_data_attr *a)
+void damon_destroy_counter(struct damon_counter *a)
 {
-	damon_del_data_attr(a);
-	damon_free_data_attr(a);
+	damon_del_counter(a);
+	damon_free_counter(a);
 }
 
-static struct damon_data_attr *damon_nth_data_attr(int n,
-		struct damon_ctx *ctx)
+static struct damon_counter *damon_nth_counter(int n, struct damon_ctx *ctx)
 {
-	struct damon_data_attr *a;
+	struct damon_counter *c;
 	int i = 0;
 
-	damon_for_each_data_attr(a, ctx) {
+	damon_for_each_counter(c, ctx) {
 		if (i++ == n)
-			return a;
+			return c;
 	}
 	return NULL;
 }
@@ -811,7 +809,7 @@ struct damon_ctx *damon_new_ctx(void)
 	ctx->attrs.min_nr_regions = 10;
 	ctx->attrs.max_nr_regions = 1000;
 
-	INIT_LIST_HEAD(&ctx->data_attrs);
+	INIT_LIST_HEAD(&ctx->counters);
 
 	ctx->sample_control.primitives_enabled.page_table = true;
 	INIT_LIST_HEAD(&ctx->sample_control.sample_filters);
@@ -837,15 +835,15 @@ void damon_destroy_ctx(struct damon_ctx *ctx)
 {
 	struct damos *s, *next_s;
 	struct damon_sample_filter *f, *next_f;
-	struct damon_data_attr *a, *next_a;
+	struct damon_counter *c, *next_c;
 
 	damon_destroy_targets(ctx);
 
 	damon_for_each_scheme_safe(s, next_s, ctx)
 		damon_destroy_scheme(s);
 
-	damon_for_each_data_attr_safe(a, next_a, ctx)
-		damon_destroy_data_attr(a);
+	damon_for_each_counter_safe(c, next_c, ctx)
+		damon_destroy_counter(c);
 
 	damon_for_each_sample_filter_safe(f, next_f, &ctx->sample_control)
 		damon_destroy_sample_filter(f, &ctx->sample_control);
@@ -1535,67 +1533,66 @@ static int damon_commit_targets(
 	return 0;
 }
 
-static void damon_commit_filter(struct damon_filter *dst,
-		struct damon_filter *src)
+static void damon_commit_test(struct damon_test *dst,
+		struct damon_test *src)
 {
 	dst->type = src->type;
 	dst->matching = src->matching;
-	dst->allow = src->allow;
+	dst->pass = src->pass;
 }
 
-static int damon_commit_filters(struct damon_data_attr *dst,
-		struct damon_data_attr *src)
+static int damon_commit_tests(struct damon_counter *dst,
+		struct damon_counter *src)
 {
-	struct damon_filter *dst_filter, *next, *src_filter, *new_filter;
+	struct damon_test *dst_test, *next, *src_test, *new_test;
 	int i = 0, j = 0;
 
-	damon_for_each_filter_safe(dst_filter, next, dst) {
-		src_filter = damon_nth_filter(i++, src);
-		if (src_filter)
-			damon_commit_filter(dst_filter, src_filter);
+	damon_for_each_test_safe(dst_test, next, dst) {
+		src_test = damon_nth_test(i++, src);
+		if (src_test)
+			damon_commit_test(dst_test, src_test);
 		else
-			damon_destroy_filter(dst_filter);
+			damon_destroy_test(dst_test);
 	}
 
-	damon_for_each_filter_safe(src_filter, next, src) {
+	damon_for_each_test_safe(src_test, next, src) {
 		if (j++ < i)
 			continue;
 
-		new_filter = damon_new_filter(src_filter->type,
-				src_filter->matching, src_filter->allow);
-		if (!new_filter)
+		new_test = damon_new_test(src_test->type, src_test->matching,
+				src_test->pass);
+		if (!new_test)
 			return -ENOMEM;
-		damon_add_filter(dst, new_filter);
+		damon_add_test(dst, new_test);
 	}
 	return 0;
 }
 
-static int damon_commit_data_attrs(struct damon_ctx *dst,
-		struct damon_ctx *src)
+static int damon_commit_counters(struct damon_ctx *dst, struct damon_ctx *src)
 {
-	struct damon_data_attr *dst_attr, *next, *src_attr, *new_attr;
+	struct damon_counter *dst_counter, *next, *src_counter, *new_counter;
 	int i = 0, j = 0, err;
 
-	damon_for_each_data_attr_safe(dst_attr, next, dst) {
-		src_attr = damon_nth_data_attr(i++, src);
-		if (src_attr) {
-			err = damon_commit_filters(dst_attr, src_attr);
+	damon_for_each_counter_safe(dst_counter, next, dst) {
+		src_counter = damon_nth_counter(i++, src);
+		if (src_counter) {
+			err = damon_commit_tests(dst_counter, src_counter);
 			if (err)
 				return err;
 		} else {
-			damon_destroy_data_attr(dst_attr);
+			damon_destroy_counter(dst_counter);
 		}
 	}
 
-	damon_for_each_data_attr_safe(src_attr, next, src) {
+	damon_for_each_counter_safe(src_counter, next, src) {
 		if (j++ < i)
 			continue;
 
-		new_attr = damon_new_data_attr();
-		if (!new_attr)
+		new_counter = damon_new_counter();
+		if (!new_counter)
 			return -ENOMEM;
-		damon_add_data_attr(dst, new_attr);
-		err = damon_commit_filters(new_attr, src_attr);
+		damon_add_counter(dst, new_counter);
+		err = damon_commit_tests(new_counter, src_counter);
 		if (err)
 			return err;
 	}
@@ -1734,7 +1731,7 @@ int damon_commit_ctx(struct damon_ctx *dst, struct damon_ctx *src)
 	}
 	dst->pause = src->pause;
 	dst->ops = src->ops;
-	err = damon_commit_data_attrs(dst, src);
+	err = damon_commit_counters(dst, src);
 	if (err)
 		return err;
 	err = damon_commit_sample_control(&dst->sample_control,
@@ -3652,8 +3649,8 @@ static int kdamond_fn(void *data)
 			max_nr_accesses = kdamond_check_reported_accesses(ctx);
 		else if (ctx->ops.check_accesses)
 			max_nr_accesses = ctx->ops.check_accesses(ctx);
-		if (ctx->ops.check_data_attrs)
-			ctx->ops.check_data_attrs(ctx);
+		if (ctx->ops.test_counters)
+			ctx->ops.test_counters(ctx);
 
 		if (time_after_eq(ctx->passed_sample_intervals,
 					next_aggregation_sis)) {
diff --git a/mm/damon/paddr.c b/mm/damon/paddr.c
index 76e946fc6da66..4788abce08a50 100644
--- a/mm/damon/paddr.c
+++ b/mm/damon/paddr.c
@@ -184,15 +184,15 @@ static unsigned int damon_pa_check_accesses(struct damon_ctx *ctx)
 	return max_nr_accesses;
 }
 
-static bool damon_pa_is_attr(phys_addr_t pa, struct damon_data_attr *a)
+static bool damon_pa_tests_pass(phys_addr_t pa, struct damon_counter *c)
 {
-	struct damon_filter *f;
-	bool default_allow = true;
+	struct damon_test *t;
+	bool default_pass = true;
 
-	damon_for_each_filter(f, a) {
+	damon_for_each_test(t, c) {
 		bool matched;
 
-		if (f->type == DAMON_FILTER_TYPE_ANON) {
+		if (t->type == DAMON_TEST_TYPE_ANON) {
 			struct folio *folio = damon_get_folio(PHYS_PFN(pa));
 
 			if (!folio)
@@ -201,28 +201,28 @@ static bool damon_pa_is_attr(phys_addr_t pa, struct damon_data_attr *a)
 				matched = folio_test_anon(folio);
 		}
 		if (matched)
-			return f->allow;
-		default_allow = !f->allow;
+			return t->pass;
+		default_pass = !t->pass;
 	}
-	return default_allow;
+	return default_pass;
 }
 
-static void damon_pa_check_data_attrs(struct damon_ctx *ctx)
+static void damon_pa_test_counters(struct damon_ctx *ctx)
 {
 	struct damon_target *t;
 	struct damon_region *r;
-	struct damon_data_attr *a;
+	struct damon_counter *c;
 
 	damon_for_each_target(t, ctx) {
 		damon_for_each_region(r, t) {
 			int i = 0;
 
-			damon_for_each_data_attr(a, ctx) {
+			damon_for_each_counter(c, ctx) {
 				phys_addr_t pa;
 
 				pa = damon_pa_phys_addr(r->sampling_addr,
 						ctx->addr_unit);
-				if (damon_pa_is_attr(pa, a))
+				if (damon_pa_tests_pass(pa, c))
 					r->attr_counts[i]++;
 				i++;
 			}
@@ -574,7 +574,7 @@ static int __init damon_pa_initcall(void)
 		.update = NULL,
 		.prepare_access_checks = damon_pa_prepare_access_checks,
 		.check_accesses = damon_pa_check_accesses,
-		.check_data_attrs = damon_pa_check_data_attrs,
+		.test_counters = damon_pa_test_counters,
 		.target_valid = NULL,
 		.apply_scheme = damon_pa_apply_scheme,
 		.get_scheme_score = damon_pa_scheme_score,
diff --git a/mm/damon/sysfs.c b/mm/damon/sysfs.c
index a2395e12dc08b..e564e01527802 100644
--- a/mm/damon/sysfs.c
+++ b/mm/damon/sysfs.c
@@ -748,30 +748,30 @@ static const struct kobj_type damon_sysfs_intervals_ktype = {
 };
 
 /*
- * filter directory
+ * test directory
  */
 
-struct damon_sysfs_filter {
+struct damon_sysfs_test {
 	struct kobject kobj;
-	enum damon_filter_type type;
+	enum damon_test_type type;
 	bool matching;
-	bool allow;
+	bool pass;
 };
 
-static struct damon_sysfs_filter *damon_sysfs_filter_alloc(void)
+static struct damon_sysfs_test *damon_sysfs_test_alloc(void)
 {
-	return kzalloc_obj(struct damon_sysfs_filter);
+	return kzalloc_obj(struct damon_sysfs_test);
 }
 
-struct damon_sysfs_filter_type_name {
-	enum damon_filter_type type;
+struct damon_sysfs_test_type_name {
+	enum damon_test_type type;
 	char *name;
 };
 
-static const struct damon_sysfs_filter_type_name
-damon_sysfs_filter_type_names[] = {
+static const struct damon_sysfs_test_type_name
+damon_sysfs_test_type_names[] = {
 	{
-		.type = DAMON_FILTER_TYPE_ANON,
+		.type = DAMON_TEST_TYPE_ANON,
 		.name = "anon",
 	},
 };
@@ -779,15 +779,15 @@ damon_sysfs_filter_type_names[] = {
 static ssize_t type_show(struct kobject *kobj,
 		struct kobj_attribute *attr, char *buf)
 {
-	struct damon_sysfs_filter *filter = container_of(kobj,
-			struct damon_sysfs_filter, kobj);
+	struct damon_sysfs_test *test = container_of(kobj,
+			struct damon_sysfs_test, kobj);
 	int i;
 
-	for (i = 0; i < ARRAY_SIZE(damon_sysfs_filter_type_names); i++) {
-		const struct damon_sysfs_filter_type_name *type_name;
+	for (i = 0; i < ARRAY_SIZE(damon_sysfs_test_type_names); i++) {
+		const struct damon_sysfs_test_type_name *type_name;
 
-		type_name = &damon_sysfs_filter_type_names[i];
-		if (type_name->type == filter->type)
+		type_name = &damon_sysfs_test_type_names[i];
+		if (type_name->type == test->type)
 			return sysfs_emit(buf, "%s\n", type_name->name);
 	}
 	return -EINVAL;
@@ -796,17 +796,17 @@ static ssize_t type_show(struct kobject *kobj,
 static ssize_t type_store(struct kobject *kobj,
 		struct kobj_attribute *attr, const char *buf, size_t count)
 {
-	struct damon_sysfs_filter *filter = container_of(kobj,
-			struct damon_sysfs_filter, kobj);
+	struct damon_sysfs_test *test = container_of(kobj,
+			struct damon_sysfs_test, kobj);
 	ssize_t ret = -EINVAL;
 	int i;
 
-	for (i = 0; i < ARRAY_SIZE(damon_sysfs_filter_type_names); i++) {
-		const struct damon_sysfs_filter_type_name *type_name;
+	for (i = 0; i < ARRAY_SIZE(damon_sysfs_test_type_names); i++) {
+		const struct damon_sysfs_test_type_name *type_name;
 
-		type_name = &damon_sysfs_filter_type_names[i];
+		type_name = &damon_sysfs_test_type_names[i];
 		if (sysfs_streq(buf, type_name->name)) {
-			filter->type = type_name->type;
+			test->type = type_name->type;
 			ret = count;
 			break;
 		}
@@ -817,160 +817,160 @@ static ssize_t type_store(struct kobject *kobj,
 static ssize_t matching_show(struct kobject *kobj,
 		struct kobj_attribute *attr, char *buf)
 {
-	struct damon_sysfs_filter *filter = container_of(kobj,
