From: SeongJae Park <sj@kernel.org>
Date: Mon, 13 Apr 2026 22:47:43 -0700
Subject: [PATCH] mm/damon/stat: fixup damon_kdamond_pid() failure handling

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/stat.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/mm/damon/stat.c b/mm/damon/stat.c
index 21fa04d95eeac..510c593a313b8 100644
--- a/mm/damon/stat.c
+++ b/mm/damon/stat.c
@@ -270,8 +270,12 @@ static int damon_stat_start(void)
 		return err;
 	}
 	kdamond_pid = damon_kdamond_pid(damon_stat_context);
-	if (kdamond_pid < 0)
-		return kdamond_pid;
+	if (kdamond_pid < 0) {
+		err = kdamond_pid;
+		kdamond_pid = -1;
+		damon_destroy_ctx(damon_stat_context);
+		damon_stat_context = NULL;
+		return err;
 
 	damon_stat_last_refresh_jiffies = jiffies;
 	call_control.data = damon_stat_context;
-- 
2.47.3

