From: SeongJae Park <sj@kernel.org>
Date: Mon, 15 Jun 2026 21:46:21 -0700
Subject: [PATCH] mm/damon/sysfs: do not directly access dmon_ctx->ops

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/sysfs.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mm/damon/sysfs.c b/mm/damon/sysfs.c
index 6d223dcb9976e..4b80bbbf12039 100644
--- a/mm/damon/sysfs.c
+++ b/mm/damon/sysfs.c
@@ -2023,7 +2023,7 @@ static int damon_sysfs_add_targets(struct damon_ctx *ctx,
 	int i, err;
 
 	/* Multiple physical address space monitoring targets makes no sense */
-	if (ctx->ops.id == DAMON_OPS_PADDR && sysfs_targets->nr > 1)
+	if (!damon_target_has_pid(ctx) && sysfs_targets->nr > 1)
 		return -EINVAL;
 
 	for (i = 0; i < sysfs_targets->nr; i++) {
-- 
2.47.3

