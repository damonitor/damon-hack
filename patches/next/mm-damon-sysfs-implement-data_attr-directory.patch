From: SeongJae Park <sj@kernel.org>
Date: Sat, 18 Apr 2026 14:51:13 -0700
Subject: [PATCH] mm/damon/sysfs: implement data_attr directory

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/sysfs.c | 54 ++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 54 insertions(+)

diff --git a/mm/damon/sysfs.c b/mm/damon/sysfs.c
index 0521fe381233a..f0772e531b8e6 100644
--- a/mm/damon/sysfs.c
+++ b/mm/damon/sysfs.c
@@ -1010,6 +1010,60 @@ static const struct kobj_type damon_sysfs_filters_ktype = {
 	.default_groups = damon_sysfs_filters_groups,
 };
 
+/*
+ * data attribute directory
+ */
+
+struct damon_sysfs_data_attr {
+	struct kobject kobj;
+	struct damon_sysfs_filters *filters;
+};
+
+static struct damon_sysfs_data_attr *damon_sysfs_data_attr_alloc(void)
+{
+	return kzalloc_obj(struct damon_sysfs_data_attr);
+}
+
+static int damon_sysfs_data_attr_add_dirs(struct damon_sysfs_data_attr *attr)
+{
+	struct damon_sysfs_filters *filters;
+	int err;
+
+	filters = damon_sysfs_filters_alloc();
+	if (!filters)
+		return -ENOMEM;
+
+	err = kobject_init_and_add(&filters->kobj, &damon_sysfs_filters_ktype,
+			&attr->kobj, "filters");
+	if (err) {
+		kobject_put(&filters->kobj);
+		attr->filters = NULL;
+	}
+	return err;
+}
+
+static void damon_sysfs_data_attr_rm_dirs(struct damon_sysfs_data_attr *attr)
+{
+	if (attr->filters)
+		kobject_put(&attr->filters->kobj);
+}
+
+static void damon_sysfs_data_attr_release(struct kobject *kobj)
+{
+	kfree(container_of(kobj, struct damon_sysfs_data_attr, kobj));
+}
+
+static struct attribute *damon_sysfs_data_attr_attrs[] = {
+	NULL,
+};
+ATTRIBUTE_GROUPS(damon_sysfs_data_attr);
+
+const struct kobj_type damon_sysfs_data_attr_ktype = {
+	.release = damon_sysfs_data_attr_release,
+	.sysfs_ops = &kobj_sysfs_ops,
+	.default_groups = damon_sysfs_data_attr_groups,
+};
+
 /*
  * monitoring_attrs directory
  */
-- 
2.47.3

