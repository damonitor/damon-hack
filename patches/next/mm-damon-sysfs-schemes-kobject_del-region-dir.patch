From: SeongJae Park <sj@kernel.org>
Date: Sun, 24 May 2026 12:04:46 -0700
Subject: [PATCH] mm/damon/sysfs[-schemes]: kobject_del() region dir

DAMON sysfs only puts the region directory kobject.  On
CONFIG_DEBUG_KOBJECT_RELEASE enabled kernel, this causes below verbose
kernel log.

    # damo start --damos_action stat
    # cd /sys/kernel/mm/damon/admin/kdamonds/0/
    # for i in {1..2}; do echo update_schemes_tried_regions > state; done
    # dmesg
    [...]
    [   82.669096] sysfs: cannot create duplicate filename
    '/kernel/mm/damon/admin/kdamonds/0/contexts/0/schemes/0/tried_regions/0'
    [   82.671526] CPU: 1 UID: 0 PID: 770 Comm: kdamond.0 Not tainted
    7.1.0-rc4-mm-new-damon+ #8 PREEMPT(full)
    [   82.671529] Hardware name: QEMU Standard PC (i440FX + PIIX, 1996),
    BIOS 1.16.3-debian-1.16.3-2 04/01/2014
    [   82.671531] Call Trace:
    [   82.671533]  <TASK>
    [   82.671535]  dump_stack_lvl+0x5d/0x80
    [   82.671541]  sysfs_warn_dup.cold+0x17/0x27
    [   82.671543]  sysfs_create_dir_ns+0xcc/0xe0
    [   82.671549]  kobject_add_internal+0xba/0x260
    [   82.671554]  kobject_init_and_add+0x90/0xc0
    [   82.671557]  ? __kmalloc_cache_noprof+0x15e/0x480
    [   82.671562]  damos_sysfs_populate_region_dir+0x18f/0x580
    [   82.671568]  damon_sysfs_schemes_tried_regions_upd_one+0x33/0x40
    [   82.671573]  kdamond_fn+0x1c60/0x2070
    [   82.671578]  ? __pfx_kdamond_fn+0x10/0x10
    [   82.671580]  ? __pfx_kdamond_fn+0x10/0x10
    [   82.671581]  kthread+0xe3/0x120
    [   82.671584]  ? __pfx_kthread+0x10/0x10
    [   82.671585]  ret_from_fork+0x230/0x2f0
    [   82.671590]  ? __pfx_kthread+0x10/0x10
    [   82.671591]  ret_from_fork_asm+0x1a/0x30
    [   82.671595]  </TASK>
    [   82.671600] kobject: kobject_add_internal failed for 0 with -EEXIST,
    don't try to register things with the same name in the same directory.
    [...]

Technically speaking not a real issue, but better to keep the kernel log
clean and work in more deterministic way.

Remove the directory synchronously using kobject_del().

The issue was originally discovered [1] by Sashiko.

[1] https://lore.kernel.org/20260517205828.6204-1-sj@kernel.org

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/sysfs-schemes.c | 14 +++++++++++---
 mm/damon/sysfs.c         | 13 +++++++++++--
 2 files changed, 22 insertions(+), 5 deletions(-)

diff --git a/mm/damon/sysfs-schemes.c b/mm/damon/sysfs-schemes.c
index 26c17c98c8659..4e07aac4c6da7 100644
--- a/mm/damon/sysfs-schemes.c
+++ b/mm/damon/sysfs-schemes.c
@@ -334,6 +334,7 @@ static void damon_sysfs_scheme_regions_rm_dirs(
 	list_for_each_entry_safe(r, next, &regions->regions_list, list) {
 		damos_sysfs_region_rm_dirs(r);
 		list_del(&r->list);
+		kobject_del(&r->kobj);
 		kobject_put(&r->kobj);
 		regions->nr_regions--;
 	}
@@ -913,8 +914,10 @@ static void damon_sysfs_scheme_filters_rm_dirs(
 	struct damon_sysfs_scheme_filter **filters_arr = filters->filters_arr;
 	int i;
 
-	for (i = 0; i < filters->nr; i++)
+	for (i = 0; i < filters->nr; i++) {
+		kobject_del(&filters_arr[i]->kobj);
 		kobject_put(&filters_arr[i]->kobj);
+	}
 	filters->nr = 0;
 	kfree(filters_arr);
 	filters->filters_arr = NULL;
@@ -1462,8 +1465,10 @@ static void damos_sysfs_quota_goals_rm_dirs(
 	struct damos_sysfs_quota_goal **goals_arr = goals->goals_arr;
 	int i;
 
-	for (i = 0; i < goals->nr; i++)
+	for (i = 0; i < goals->nr; i++) {
+		kobject_del(&goals_arr[i]->kobj);
 		kobject_put(&goals_arr[i]->kobj);
+	}
 	goals->nr = 0;
 	kfree(goals_arr);
 	goals->goals_arr = NULL;
@@ -2143,8 +2148,10 @@ static void damos_sysfs_dests_rm_dirs(
 	struct damos_sysfs_dest **dests_arr = dests->dests_arr;
 	int i;
 
-	for (i = 0; i < dests->nr; i++)
+	for (i = 0; i < dests->nr; i++) {
+		kobject_del(&dests_arr[i]->kobj);
 		kobject_put(&dests_arr[i]->kobj);
+	}
 	dests->nr = 0;
 	kfree(dests_arr);
 	dests->dests_arr = NULL;
@@ -2696,6 +2703,7 @@ void damon_sysfs_schemes_rm_dirs(struct damon_sysfs_schemes *schemes)
 
 	for (i = 0; i < schemes->nr; i++) {
 		damon_sysfs_scheme_rm_dirs(schemes_arr[i]);
+		kobject_del(&schemes_arr[i]->kobj);
 		kobject_put(&schemes_arr[i]->kobj);
 	}
 	schemes->nr = 0;
diff --git a/mm/damon/sysfs.c b/mm/damon/sysfs.c
index 3dbb14a478512..ef4dc040cd3d7 100644
--- a/mm/damon/sysfs.c
+++ b/mm/damon/sysfs.c
@@ -107,8 +107,10 @@ static void damon_sysfs_regions_rm_dirs(struct damon_sysfs_regions *regions)
 	struct damon_sysfs_region **regions_arr = regions->regions_arr;
 	int i;
 
-	for (i = 0; i < regions->nr; i++)
+	for (i = 0; i < regions->nr; i++) {
+		kobject_del(&regions_arr[i]->kobj);
 		kobject_put(&regions_arr[i]->kobj);
+	}
 	regions->nr = 0;
 	kfree(regions_arr);
 	regions->regions_arr = NULL;
@@ -333,6 +335,7 @@ static void damon_sysfs_targets_rm_dirs(struct damon_sysfs_targets *targets)
 
 	for (i = 0; i < targets->nr; i++) {
 		damon_sysfs_target_rm_dirs(targets_arr[i]);
+		kobject_del(&targets_arr[i]->kobj);
 		kobject_put(&targets_arr[i]->kobj);
 	}
 	targets->nr = 0;
@@ -957,8 +960,10 @@ static void damon_sysfs_filters_rm_dirs(struct damon_sysfs_filters *filters)
 	struct damon_sysfs_filter **filters_arr = filters->filters_arr;
 	int i;
 
-	for (i = 0; i < filters->nr; i++)
+	for (i = 0; i < filters->nr; i++) {
+		kobject_del(&filters_arr[i]->kobj);
 		kobject_put(&filters_arr[i]->kobj);
+	}
 	filters->nr = 0;
 	kfree(filters_arr);
 	filters->filters_arr = NULL;
@@ -1091,6 +1096,7 @@ static void damon_sysfs_probe_rm_dirs(struct damon_sysfs_probe *attr)
 {
 	if (attr->filters) {
 		damon_sysfs_filters_rm_dirs(attr->filters);
+		kobject_del(&attr->filters->kobj);
 		kobject_put(&attr->filters->kobj);
 	}
 }
@@ -1134,6 +1140,7 @@ static void damon_sysfs_probes_rm_dirs(
 
 	for (i = 0; i < probes->nr; i++) {
 		damon_sysfs_probe_rm_dirs(probes_arr[i]);
+		kobject_del(&probes_arr[i]->kobj);
 		kobject_put(&probes_arr[i]->kobj);
 	}
 	probes->nr = 0;
@@ -1664,6 +1671,7 @@ static void damon_sysfs_contexts_rm_dirs(struct damon_sysfs_contexts *contexts)
 
 	for (i = 0; i < contexts->nr; i++) {
 		damon_sysfs_context_rm_dirs(contexts_arr[i]);
+		kobject_del(&contexts_arr[i]->kobj);
 		kobject_put(&contexts_arr[i]->kobj);
 	}
 	contexts->nr = 0;
@@ -2498,6 +2506,7 @@ static void damon_sysfs_kdamonds_rm_dirs(struct damon_sysfs_kdamonds *kdamonds)
 
 	for (i = 0; i < kdamonds->nr; i++) {
 		damon_sysfs_kdamond_rm_dirs(kdamonds_arr[i]);
+		kobject_del(&kdamonds_arr[i]->kobj);
 		kobject_put(&kdamonds_arr[i]->kobj);
 	}
 	kdamonds->nr = 0;
-- 
2.47.3

