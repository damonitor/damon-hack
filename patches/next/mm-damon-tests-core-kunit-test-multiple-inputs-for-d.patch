From: SeongJae Park <sj@kernel.org>
Date: Thu, 25 Jun 2026 18:09:38 -0700
Subject: [PATCH] mm/damon/tests/core-kunit: test multiple inputs for
 damon_rand()

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/tests/core-kunit.h | 21 +++++++++++++++------
 1 file changed, 15 insertions(+), 6 deletions(-)

diff --git a/mm/damon/tests/core-kunit.h b/mm/damon/tests/core-kunit.h
index 7eaccbdd00ef7..c5b1f4eecfce1 100644
--- a/mm/damon/tests/core-kunit.h
+++ b/mm/damon/tests/core-kunit.h
@@ -1497,18 +1497,27 @@ static void damon_test_walk_control_obsolete(struct kunit *test)
 	damon_destroy_ctx(ctx);
 }
 
+static void damon_test_rand_for(struct kunit *test, struct damon_ctx *ctx,
+		unsigned long l, unsigned long r)
+{
+	unsigned long rnd = damon_rand(ctx, l, r);
+
+	KUNIT_EXPECT_GE(test, rnd, l);
+	KUNIT_EXPECT_LT(test, rnd, r);
+}
+
 static void damon_test_rand(struct kunit *test)
 {
 	struct damon_ctx ctx;
+	unsigned long test_cases[][2] = {
+		{0, 10}, {42, 4242}, {UINT_MAX, (unsigned long)UINT_MAX + 10},
+		{UINT_MAX, ULONG_MAX},};
 	int i;
 
 	prandom_seed_state(&ctx.rnd_state, get_random_u64());
-	for (i = 0; i < 10000; i++) {
-		unsigned long rnd = damon_rand(&ctx, 0, 10);
-
-		KUNIT_EXPECT_GE(test, rnd, 0);
-		KUNIT_EXPECT_LE(test, rnd, 9);
-	}
+	for (i = 0; i < ARRAY_SIZE(test_cases); i++)
+		damon_test_rand_for(test, &ctx, test_cases[i][0],
+				test_cases[i][1]);
 }
 
 static struct kunit_case damon_test_cases[] = {
-- 
2.47.3

