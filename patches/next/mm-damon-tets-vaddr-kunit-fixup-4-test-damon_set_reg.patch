From: SeongJae Park <sj@kernel.org>
Date: Wed, 20 May 2026 06:54:03 -0700
Subject: [PATCH] mm/damon/tets/vaddr-kunit: (fixup 4) test damon_set_regions()
 failure and free ranges

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/tests/vaddr-kunit.h | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/mm/damon/tests/vaddr-kunit.h b/mm/damon/tests/vaddr-kunit.h
index 23be9c3be75fa..de30db9b753e5 100644
--- a/mm/damon/tests/vaddr-kunit.h
+++ b/mm/damon/tests/vaddr-kunit.h
@@ -149,9 +149,15 @@ static void damon_do_test_apply_three_regions(struct kunit *test,
 		ranges[i].start = regions[i * 2];
 		ranges[i].end = regions[i * 2 + 1];
 	}
-	damon_set_regions(t, ranges, nr_regions / 2, DAMON_MIN_REGION_SZ);
+	if (damon_set_regions(t, ranges, nr_regions / 2,
+				DAMON_MIN_REGION_SZ)) {
+		kfree(ranges);
+		kunit_skip(test, "damon_set_regions() fail");
+	}
+	kfree(ranges);
 
-	damon_set_regions(t, three_regions, 3, DAMON_MIN_REGION_SZ);
+	if (damon_set_regions(t, three_regions, 3, DAMON_MIN_REGION_SZ))
+		kunit_skip(test, "second damon_set_regions() fail");
 
 	for (i = 0; i < nr_expected / 2; i++) {
 		r = __nth_region_of(t, i);
-- 
