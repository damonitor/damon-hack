From: SeongJae Park <sj@kernel.org>
Date: Wed, 27 May 2026 18:02:12 -0700
Subject: [PATCH] mm/damonn/lru_sort: handle ctx allocation failure

Fixes: c4a8e662c839 ("mm/damon/lru_sort: use damon_initialized()")
Cc: <stable@vger.kernel.org> # 6.18.x
Signed-off-by: SeongJae Park <sj@kernel.org>
---
 mm/damon/lru_sort.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/mm/damon/lru_sort.c b/mm/damon/lru_sort.c
index eca88ed941b32..5e88a77c781ae 100644
--- a/mm/damon/lru_sort.c
+++ b/mm/damon/lru_sort.c
@@ -476,6 +476,13 @@ static int damon_lru_sort_enabled_store(const char *val,
 	if (!damon_initialized())
 		return 0;
 
+	/* init function's allocation could be failed. */
+	if (!ctx) {
+		err = damon_modules_new_paddr_ctx_target(&ctx, &target);
+		if (!err)
+			return -ENOMEM;;
+	}
+
 	return damon_lru_sort_turn(enabled);
 }
 
-- 
