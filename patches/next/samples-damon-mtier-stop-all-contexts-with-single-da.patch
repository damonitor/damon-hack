From: SJ Park <sj@kernel.org>
Date: Tue, 9 Jun 2026 22:36:02 -0700
Subject: [PATCH] samples/damon/mtier: stop all contexts with single
 damon_stop() call

Signed-off-by: SJ Park <sj@kernel.org>
---
 mm/damon/core.c       | 1 -
 samples/damon/mtier.c | 3 +--
 2 files changed, 1 insertion(+), 3 deletions(-)

diff --git a/mm/damon/core.c b/mm/damon/core.c
index c5d12efec3eee..659cf35093dd2 100644
--- a/mm/damon/core.c
+++ b/mm/damon/core.c
@@ -2123,7 +2123,6 @@ void damon_stop(struct damon_ctx **ctxs, int nr_ctxs)
 	for (i = 0; i < nr_ctxs; i++)
 		/* nr_running_ctxs is decremented in kdamond_fn */
 		__damon_stop(ctxs[i]);
-	return 0;
 }
 
 /**
diff --git a/samples/damon/mtier.c b/samples/damon/mtier.c
index e567f4edd80ea..564212e054dee 100644
--- a/samples/damon/mtier.c
+++ b/samples/damon/mtier.c
@@ -202,8 +202,7 @@ static int damon_sample_mtier_start(void)
 
 static void damon_sample_mtier_stop(void)
 {
-	damon_stop(ctxs, 1);
-	damon_stop(&ctxs[1], 1);
+	damon_stop(ctxs, 2);
 	damon_destroy_ctx(ctxs[0]);
 	damon_destroy_ctx(ctxs[1]);
 }
-- 
2.47.3

