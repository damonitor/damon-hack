From: SeongJae Park <sj@kernel.org>
Date: Sat, 25 Apr 2026 09:10:14 -0700
Subject: [PATCH] selftests/damon/sysfs.sh: fixup for the renaming

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 tools/testing/selftests/damon/sysfs.sh | 63 +++++++++++++-------------
 1 file changed, 32 insertions(+), 31 deletions(-)

diff --git a/tools/testing/selftests/damon/sysfs.sh b/tools/testing/selftests/damon/sysfs.sh
index 44b118ef5383d..1ac3e2ce8e448 100755
--- a/tools/testing/selftests/damon/sysfs.sh
+++ b/tools/testing/selftests/damon/sysfs.sh
@@ -291,50 +291,51 @@ test_intervals()
 	ensure_file "$intervals_dir/update_us" "exist" "600"
 }
 
-test_test()
+test_damon_filter()
 {
-	test_dir=$1
-	ensure_file "$test_dir/type" "exist" "600"
-	ensure_write_succ "$test_dir/type" "anon" "valid input"
-	ensure_write_fail "$test_dir/type" "foo" "invalid input"
-	ensure_file "$test_dir/matching" "exist" "600"
+	damon_filter_dir=$1
+	ensure_file "$damon_filter_dir/type" "exist" "600"
+	ensure_write_succ "$damon_filter_dir/type" "anon" "valid input"
+	ensure_write_fail "$damon_filter_dir/type" "foo" "invalid input"
+	ensure_file "$damon_filter_dir/matching" "exist" "600"
+	ensure_file "$damon_filter_dir/allow" "exist" "600"
 }
 
-test_attr_tests()
+test_damon_filters()
 {
-	tests_dir=$1
-	ensure_dir "$tests_dir" "exist"
-	ensure_file "$tests_dir/nr_tests" "exist" "600"
-	ensure_write_succ  "$tests_dir/nr_tests" "1" "valid input"
-	test_test "$tests_dir/0"
+	filters_dir=$1
+	ensure_dir "$filters_dir" "exist"
+	ensure_file "$filters_dir/nr_filters" "exist" "600"
+	ensure_write_succ  "$filters_dir/nr_filters" "1" "valid input"
+	test_damon_filter "$filters_dir/0"
 
-	ensure_write_succ  "$tests_dir/nr_tests" "2" "valid input"
-	test_test "$tests_dir/0"
-	test_test "$tests_dir/1"
+	ensure_write_succ  "$filters_dir/nr_filters" "2" "valid input"
+	test_damon_filter "$filters_dir/0"
+	test_damon_filter "$filters_dir/1"
 
-	ensure_write_succ "$tests_dir/nr_tests" "0" "valid input"
-	ensure_dir "$tests_dir/0" "not_exist"
-	ensure_dir "$tests_dir/1" "not_exist"
+	ensure_write_succ "$filters_dir/nr_filters" "0" "valid input"
+	ensure_dir "$filters_dir/0" "not_exist"
+	ensure_dir "$filters_dir/1" "not_exist"
 }
 
-test_counter()
+test_probe()
 {
-	attr_dir=$1
-	ensure_dir "$attr_dir" "exist"
-	test_attr_tests "$attr_dir/tests"
+	probe_dir=$1
+	ensure_dir "$probe_dir" "exist"
+	test_damon_filters "$probe_dir/filters"
 }
 
-test_counters()
+test_probes()
 {
-	attrs_dir=$1
-	ensure_dir "$attrs_dir" "exist"
-	ensure_file "$attrs_dir/nr_attrs" "exist" "600"
+	probes_dir=$1
+	ensure_dir "$probes_dir" "exist"
+	ensure_file "$probes_dir/nr_probes" "exist" "600"
 
-	ensure_write_succ "$attrs_dir/nr_attrs" "1" "valid input"
-	test_counter "$attrs_dir/0"
+	ensure_write_succ "$probes_dir/nr_probes" "1" "valid input"
+	test_probe "$probes_dir/0"
 
-	ensure_write_succ "$attrs_dir/nr_attrs" "0" "valid input"
-	ensure_dir "$attrs_dir/0" "not_exist"
+	ensure_write_succ "$probes_dir/nr_probes" "0" "valid input"
+	ensure_dir "$probes_dir/0" "not_exist"
 }
 
 test_monitoring_attrs()
@@ -342,7 +343,7 @@ test_monitoring_attrs()
 	monitoring_attrs_dir=$1
 	ensure_dir "$monitoring_attrs_dir" "exist"
 	test_intervals "$monitoring_attrs_dir/intervals"
-	test_counters "$monitoring_attrs_dir/counters"
+	test_probes "$monitoring_attrs_dir/probes"
 	test_range "$monitoring_attrs_dir/nr_regions"
 }
 
-- 
2.47.3

