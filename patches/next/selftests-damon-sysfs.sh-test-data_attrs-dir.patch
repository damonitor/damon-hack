From: SeongJae Park <sj@kernel.org>
Date: Sun, 19 Apr 2026 10:26:17 -0700
Subject: [PATCH] selftests/damon/sysfs.sh: test data_attrs dir

Signed-off-by: SeongJae Park <sj@kernel.org>
---
 tools/testing/selftests/damon/sysfs.sh | 47 ++++++++++++++++++++++++++
 1 file changed, 47 insertions(+)

diff --git a/tools/testing/selftests/damon/sysfs.sh b/tools/testing/selftests/damon/sysfs.sh
index 83e3b7f63d81c..91e9447052994 100755
--- a/tools/testing/selftests/damon/sysfs.sh
+++ b/tools/testing/selftests/damon/sysfs.sh
@@ -291,11 +291,58 @@ test_intervals()
 	ensure_file "$intervals_dir/update_us" "exist" "600"
 }
 
+test_filter()
+{
+	filter_dir=$1
+	ensure_file "$filter_dir/type" "exist" "600"
+	ensure_write_succ "$filter_dir/type" "anon" "valid input"
+	ensure_write_fail "$filter_dir/type" "foo" "invalid input"
+	ensure_file "$filter_dir/matching" "exist" "600"
+}
+
+test_attr_filters()
+{
+	filters_dir=$1
+	ensure_dir "$filters_dir" "exist"
+	ensure_file "$filters_dir/nr_filters" "exist" "600"
+	ensure_write_succ  "$filters_dir/nr_filters" "1" "valid input"
+	test_filter "$filters_dir/0"
+
+	ensure_write_succ  "$filters_dir/nr_filters" "2" "valid input"
+	test_filter "$filters_dir/0"
+	test_filter "$filters_dir/1"
+
+	ensure_write_succ "$filters_dir/nr_filters" "0" "valid input"
+	ensure_dir "$filters_dir/0" "not_exist"
+	ensure_dir "$filters_dir/1" "not_exist"
+}
+
+test_data_attr()
+{
+	attr_dir=$1
+	ensure_dir "$attr_dir" "exist"
+	test_attr_filters "$attr_dir/filters"
+}
+
+test_data_attrs()
+{
+	attrs_dir=$1
+	ensure_dir "$attrs_dir" "exist"
+	ensure_file "$attrs_dir/nr_attrs" "exist" "600"
+
+	ensure_write_succ "$attrs_dir/nr_attrs" "1" "valid input"
+	test_data_attr "$attrs_dir/0"
+
+	ensure_write_succ "$attrs_dir/nr_attrs" "0" "valid input"
+	ensure_dir "$attrs_dir/0" "not_exist"
+}
+
 test_monitoring_attrs()
 {
 	monitoring_attrs_dir=$1
 	ensure_dir "$monitoring_attrs_dir" "exist"
 	test_intervals "$monitoring_attrs_dir/intervals"
+	test_data_attrs "$monitoring_attrs_dir/data_attrs"
 	test_range "$monitoring_attrs_dir/nr_regions"
 }
 
-- 
2.47.3

